@page
@model BellBeast.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Admin Login";
    Layout = "_Layout";
}

<style>
    .admin-wrap {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 28px 14px;
    }

    .admin-card {
        width: 100%;
        max-width: 520px;
        background: rgba(10, 18, 35, .62);
        border: 1px solid rgba(255,255,255,.12);
        box-shadow: 0 22px 70px rgba(0,0,0,.45);
        border-radius: 18px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        overflow: hidden;
    }

    .admin-head {
        padding: 18px 20px 10px;
        border-bottom: 1px solid rgba(255,255,255,.10);
    }

    .admin-title {
        margin: 0;
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        letter-spacing: .2px;
    }

    .admin-sub {
        margin: 6px 0 0;
        color: rgba(255,255,255,.70);
        font-size: 13px;
        line-height: 1.4;
    }

    .admin-body {
        padding: 18px 20px 20px;
    }

    .admin-row {
        margin-bottom: 12px;
    }

    .admin-label {
        display: block;
        margin-bottom: 6px;
        color: rgba(255,255,255,.80);
        font-size: 13px;
    }

    .admin-input {
        width: 100%;
        height: 42px;
        padding: 10px 12px;
        color: #fff;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.14);
        border-radius: 12px;
        outline: none;
        transition: .15s ease;
    }

        .admin-input:focus {
            border-color: rgba(96,165,250,.55);
            box-shadow: 0 0 0 3px rgba(96,165,250,.18);
            background: rgba(255,255,255,.10);
        }

        .admin-input::placeholder {
            color: rgba(255,255,255,.45);
        }

    .admin-btn {
        width: 100%;
        height: 44px;
        border: 0;
        border-radius: 12px;
        font-weight: 700;
        color: #0b1220;
        background: linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.72));
        cursor: pointer;
        transition: transform .08s ease, filter .12s ease;
    }

        .admin-btn:hover {
            filter: brightness(1.05);
        }

        .admin-btn:active {
            transform: translateY(1px);
        }

    .admin-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        border-radius: 999px;
        font-size: 12px;
        margin-bottom: 12px;
    }

    .badge-err {
        background: rgba(239,68,68,.16);
        border: 1px solid rgba(239,68,68,.35);
        color: rgba(255,255,255,.92);
    }

    .badge-ok {
        background: rgba(34,197,94,.16);
        border: 1px solid rgba(34,197,94,.35);
        color: rgba(255,255,255,.92);
    }

    .admin-foot {
        padding: 14px 20px;
        border-top: 1px solid rgba(255,255,255,.10);
        color: rgba(255,255,255,.60);
        font-size: 12px;
    }

    .muted {
        color: rgba(255,255,255,.65);
        font-size: 12px;
        margin-top: 10px;
        line-height: 1.35;
    }

    .hint {
        margin-top: 10px;
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px dashed rgba(255,255,255,.18);
        background: rgba(255,255,255,.05);
    }
</style>

<div class="admin-wrap">
    <div class="admin-card">
        <div class="admin-head">
            <h1 class="admin-title">Admin Login</h1>
            @*<div class="admin-sub">
                เข้าสู่โหมดผู้ดูแล (ตรวจผ่าน EHR แล้วต้องได้ <b>302 Found</b>)
            </div>*@
        </div>

        <div class="admin-body">

            @* Error/Info *@
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="admin-badge badge-err">⚠️ @Model.ErrorMessage</div>
            }

            <form method="post">
                <div class="admin-row">
                    <label class="admin-label">Username</label>
                    <input class="admin-input" name="Username" value="@Model.Username"
                           placeholder="00102616" autocomplete="username" />
                </div>

                <div class="admin-row">
                    <label class="admin-label">Password</label>
                    <input class="admin-input" name="Password" type="password"
                           placeholder="••••••••" autocomplete="current-password" />
                </div>

                <button class="admin-btn" type="submit">Sign in</button>

                <div class="hint muted">
                    * ระบบจะถือว่า “ผ่าน” เมื่อ POST ไป EHR แล้วได้ 302 Found<br />
                    * ถ้า EHR เปลี่ยน flow/login อาจต้องปรับ header/cookie ที่ส่งต่อ
                </div>
            </form>
        </div>

        <div class="admin-foot">
            © 2026 - BellBeast
        </div>
    </div>
</div>

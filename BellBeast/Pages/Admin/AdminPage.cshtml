</style>

<script>
    // ============================
    // Settings
    // ============================
    const POLL_SEC = 2;
    document.getElementById('pollSecText').textContent = String(POLL_SEC);

    // pause refresh while editing
    let pauseRefreshBecauseEditing = false;

    // backend base (from /api/backend-config)  -> reads App_data/backend-config.json via your razor API
    let backendBaseUrl = "";
    function api(path) {
        if (!path.startsWith("/")) path = "/" + path;
        return (backendBaseUrl || "").replace(/\/+$/, "") + path;
    }

    // cached snapshots
    let lastStatus = null;
    let lastConfig = null;

    // per-row dirty state
    const dirty = new Map(); // name -> { enabled?, intervalSec? }

    // ============================
    // Console
    // ============================
    function nowHHMMSS(){
        const d = new Date();
        const hh = String(d.getHours()).padStart(2,'0');
        const mm = String(d.getMinutes()).padStart(2,'0');
        const ss = String(d.getSeconds()).padStart(2,'0');
        return `${hh}:${mm}:${ss}`;
    }

    function logLine(level, msg){
        const box = document.getElementById('consoleBox');
        const line = document.createElement('span');
        line.className = 'log-line';
        const ts = document.createElement('span');
        ts.className = 'log-ts';
        ts.textContent = `[${nowHHMMSS()}]`;
        const m = document.createElement('span');
        m.className = (level === 'ok' ? 'log-ok' : level === 'warn' ? 'log-warn' : level === 'err' ? 'log-err' : '');
        m.textContent = msg;
        line.appendChild(ts);
        line.appendChild(m);
        box.appendChild(line);
        box.scrollTop = box.scrollHeight;
    }

    function clearConsole(){
        const box = document.getElementById('consoleBox');
        box.innerHTML = '';
        logLine('ok', 'console cleared');
    }

    // ============================
    // Engine indicator
    // ============================
    function setEnginePill(state, text){
        const dot = document.getElementById('engineDot');
        const t = document.getElementById('engineText');
        const pill = document.getElementById('pillEngine');

        t.textContent = text;

        dot.style.background = 'rgba(255,255,255,.35)';
        pill.style.borderColor = 'rgba(255,255,255,.18)';

        if (state === 'paused'){
            dot.style.background = 'rgba(255,204,102,.95)';
            pill.style.borderColor = 'rgba(255,204,102,.35)';
        } else if (state === 'running'){
            dot.style.background = 'rgba(46,229,157,.95)';
            pill.style.borderColor = 'rgba(46,229,157,.35)';
        } else if (state === 'error'){
            dot.style.background = 'rgba(255,102,122,.95)';
            pill.style.borderColor = 'rgba(255,102,122,.35)';
        }
    }

    function setButtonsEnabled(paused){
        document.getElementById('btnPause').disabled = paused === true;
        document.getElementById('btnResume').disabled = paused === false;
    }

    // ============================
    // HTTP helpers
    // ============================
    async function fetchJson(url, opt){
        const r = await fetch(url, opt);
        const ct = (r.headers.get('content-type') || '').toLowerCase();
        const text = await r.text();

        if (!ct.includes('application/json')){
            throw new Error(`Non-JSON response (${r.status}) ct='${ct}' body='${(text||'').slice(0,120)}'`);
        }

        let j;
        try { j = JSON.parse(text || '{}'); }
        catch { throw new Error(`Bad JSON (${r.status}) body='${(text||'').slice(0,120)}'`); }

        if (!r.ok){
            const e = (j && (j.error || j.message)) ? (j.error || j.message) : `HTTP ${r.status}`;
            throw new Error(e);
        }
        return j;
    }

    function fmtUtc(s){
        if (!s) return "-";
        try {
            const d = new Date(s);
            if (isNaN(d.getTime())) return String(s);
            const yy = d.getFullYear();
            const mo = String(d.getMonth()+1).padStart(2,'0');
            const da = String(d.getDate()).padStart(2,'0');
            const hh = String(d.getHours()).padStart(2,'0');
            const mm = String(d.getMinutes()).padStart(2,'0');
            const ss = String(d.getSeconds()).padStart(2,'0');
            return `${yy}-${mo}-${da} ${hh}:${mm}:${ss}`;
        } catch { return String(s); }
    }

    // ============================
    // Backend calls
    // ============================
    async function loadBackendConfig(){
        // your razor endpoint should read App_data/backend-config.json and return json
        const j = await fetchJson('/api/backend-config', { method: 'GET' });
        backendBaseUrl = (j.backendBaseUrl || '').trim().replace(/\/+$/,'');
        document.getElementById('backendBase').textContent = backendBaseUrl || '(empty)';
        logLine('ok', `backendBaseUrl = ${backendBaseUrl}`);
    }

    async function getStatus(){
        return await fetchJson(api('/admin/tasks/status'), { method: 'GET' });
    }

    async function getConfig(){
        return await fetchJson(api('/admin/tasks/config'), { method: 'GET' });
    }

    async function postConfigUpdates(updates){
        return await fetchJson(api('/admin/tasks/config'), {
            method: 'POST',
            headers: { 'Content-Type':'application/json' },
            body: JSON.stringify({ updates })
        });
    }

    async function pauseEngine(){
        try{
            await fetchJson(api('/admin/pause'), { method:'POST' });
            logLine('warn', 'engine paused');
            await forceRefresh();
        }catch(ex){
            logLine('err', `pause error: ${ex.message}`);
        }
    }

    async function resumeEngine(){
        try{
            await fetchJson(api('/admin/resume'), { method:'POST' });
            logLine('ok', 'engine resumed');
            await forceRefresh();
        }catch(ex){
            logLine('err', `resume error: ${ex.message}`);
        }
    }

    async function cancelAll(){
        try{
            await fetchJson(api('/admin/cancelall'), { method:'POST' });
            logLine('warn', 'cancelAll requested');
            await forceRefresh();
        }catch(ex){
            logLine('err', `cancelAll error: ${ex.message}`);
        }
    }

    // ============================
    // Data helpers
    // ============================
    function findStatusRow(name){
        const arr = (lastStatus && lastStatus.tasks) ? lastStatus.tasks : [];
        const key = String(name||'').toLowerCase();
        return arr.find(x => String(x.name||'').toLowerCase() === key) || null;
    }

    function findConfigRow(name){
        const arr = (lastConfig && lastConfig.tasks) ? lastConfig.tasks : [];
        const key = String(name||'').toLowerCase();
        return arr.find(x => String(x.name||'').toLowerCase() === key) || null;
    }

    function makeTag(text, kind){
        const span = document.createElement('span');
        span.className = 'tag ' + (kind || '');
        span.textContent = text;
        return span;
    }

    // ✅ Next: use status field if present, else compute from lastOk + interval
    function resolveNextUtc(configRow, statusRow){
        statusRow = statusRow || {};
        configRow = configRow || {};

        // อ่าน updatedAtUnixMs (เผื่อ serializer casing)
        const updMs = (configRow.updatedAtUnixMs ?? configRow.UpdatedAtUnixMs ?? 0) || 0;
        const now = Date.now();

        // ✅ ถ้า updMs เป็น "forcerun" (ใกล้ตอนนี้) ให้ override แม้ status จะมี next
        // window: now-2s .. now+10min (ปรับได้)
        const isForceDue = (updMs > 0 && updMs >= (now - 2000) && updMs <= (now + 10 * 60 * 1000));

        if (isForceDue && !statusRow.running){
            const d = new Date(updMs);
            if (!isNaN(d.getTime())) return d.toISOString();
        }

        // 1) backend status has explicit next -> trust it
        const candidates = [
            statusRow.nextRunAtUtc,
            statusRow.nextRunUtc,
            statusRow.nextAtUtc,
            statusRow.nextRunAt,
            statusRow.next
        ].filter(Boolean);
        if (candidates.length) return candidates[0];

        // 2) fallback: compute from lastOk/lastFail + interval
        const intervalMs = (configRow.intervalMs ?? 0) || 0;
        if (intervalMs <= 0) return null;
        if (statusRow.running) return null;

        const anchor = statusRow.lastOkAtUtc || statusRow.lastFailAtUtc || statusRow.startedAtUtc || null;
        if (!anchor) return null;

        const d = new Date(anchor);
        if (isNaN(d.getTime())) return null;

        return new Date(d.getTime() + intervalMs).toISOString();
    }

    // ============================
    // Dirty + Save
    // ============================
    function markDirty(name, patch){
        const cur = dirty.get(name) || {};
        dirty.set(name, { ...cur, ...patch });
    }

    async function saveRow(name, reason){
        try{
            const base = findConfigRow(name);
            if (!base){
                logLine('err', `save: task not found in config (${name})`);
                return;
            }

            const patch = dirty.get(name) || {};
            const enabled = (patch.enabled ?? base.enabled) === true;

            const baseSec = Math.round(((base.intervalMs || 0) / 1000));
            const intervalSec = (patch.intervalSec ?? baseSec);
            const secInt = Math.max(0, (parseInt(intervalSec, 10) || 0));
            const intervalMs = secInt * 1000;

            await postConfigUpdates([{ name, enabled, intervalMs }]);
            dirty.delete(name);

            logLine('ok', `saved(${reason||'manual'}): ${name} enabled=${enabled} intervalSec=${secInt}`);
            await forceRefresh();
        }catch(ex){
            logLine('err', `save error (${name}): ${ex.message}`);
        }
    }

    // ============================
    // Render
    // ============================
    function render(){
        const body = document.getElementById('tasksBody');
        body.innerHTML = '';

        const st = lastStatus || {};
        const paused = !!st.paused;
        setButtonsEnabled(paused);

        if (!backendBaseUrl){
            setEnginePill('error', 'no backendBaseUrl');
        } else {
            setEnginePill(paused ? 'paused' : 'running', paused ? 'paused' : 'running');
        }

        const tasks = Array.isArray(lastConfig && lastConfig.tasks) ? lastConfig.tasks : [];
        if (tasks.length === 0){
            const tr = document.createElement('tr');
            const td = document.createElement('td');
            td.colSpan = 8;
            td.className = 'muted';
            td.textContent = 'no tasks';
            tr.appendChild(td);
            body.appendChild(tr);
            return;
        }

        for (const t of tasks){
            const name = t.name || '';
            const srow = findStatusRow(name) || {};

            const intervalMs = (t.intervalMs ?? 0) || 0;
            const intervalSec = intervalMs ? Math.max(0, Math.round(intervalMs / 1000)) : 0;

            const patch = dirty.get(name) || {};
            const effectiveEnabled = (patch.enabled ?? !!t.enabled);
            const effectiveIntervalSec = (patch.intervalSec ?? intervalSec);

            const nextUtc = resolveNextUtc(t, srow);
            const running = !!srow.running;
            const runningId = srow.runningId || null;

            const lastOk = srow.lastOkAtUtc || null;
            const lastFail = srow.lastFailAtUtc || null;
            const lastErr = srow.lastError || null;

            const tr = document.createElement('tr');

            // name
            {
                const td = document.createElement('td');
                td.className = 'c-name';
                td.textContent = name;
                tr.appendChild(td);
            }

            // group
            {
                const td = document.createElement('td');
                td.className = 'c-group';
                td.textContent = (t.group || '-');
                tr.appendChild(td);
            }

            // enabled (toggle switch) + autosave immediately
            {
                const td = document.createElement('td');
                td.className = 'c-enabled';

                const label = document.createElement('label');
                label.className = 'sw ' + (effectiveEnabled ? 'on' : '');
                label.title = 'Toggle enabled (autosave)';

                const input = document.createElement('input');
                input.type = 'checkbox';
                input.checked = !!effectiveEnabled;

                const track = document.createElement('span');
                track.className = 'sw-track';

                const knob = document.createElement('span');
                knob.className = 'sw-knob';

                const txt = document.createElement('span');
                txt.textContent = effectiveEnabled ? 'ON' : 'OFF';

                track.appendChild(knob);
                label.appendChild(input);
                label.appendChild(track);
                label.appendChild(txt);

                // pause refresh while toggling (กันโดนทับ UI)
                label.addEventListener('click', () => { pauseRefreshBecauseEditing = true; });

                input.addEventListener('change', async () => {
                    const v = input.checked;
                    label.classList.toggle('on', v);
                    txt.textContent = v ? 'ON' : 'OFF';

                    markDirty(name, { enabled: v });

                    // ✅ autosave stage immediately (ส่ง enabled + ถ้ามี interval ที่แก้ค้างอยู่ก็ส่งไปด้วย)
                    await saveRow(name, 'toggle');

                    // resume
                    setTimeout(() => { pauseRefreshBecauseEditing = false; }, 250);
                });

                td.appendChild(label);
                tr.appendChild(td);
            }

            // interval seconds + save (manual)
            {
                const td = document.createElement('td');
                td.className = 'c-interval';

                const inp = document.createElement('input');
                inp.className = 'in';
                inp.type = 'number';
                inp.min = '0';
                inp.step = '1';
                inp.value = String(effectiveIntervalSec);

                inp.addEventListener('focus', () => { pauseRefreshBecauseEditing = true; });
                inp.addEventListener('blur', () => { setTimeout(() => { pauseRefreshBecauseEditing = false; }, 250); });

                inp.addEventListener('input', () => {
                    const v = parseInt(inp.value || '0', 10);
                    markDirty(name, { intervalSec: (isFinite(v) ? Math.max(0, v) : 0) });
                    // ไม่ re-render ตอนกำลังพิมพ์
                });

                const btnSave = document.createElement('button');
                btnSave.className = 'btn sm ok';
                btnSave.type = 'button';
                btnSave.textContent = 'Save';

                btnSave.addEventListener('click', async () => {
                    await saveRow(name, 'interval');
                });

                td.appendChild(inp);
                td.appendChild(btnSave);
                tr.appendChild(td);
            }

            // next
            {
                const td = document.createElement('td');
                td.className = 'c-next';
                td.textContent = fmtUtc(nextUtc);
                tr.appendChild(td);
            }

            // running
            {
                const td = document.createElement('td');
                td.className = 'c-running';

                if (running){
                    td.appendChild(makeTag('RUNNING', 'warn'));
                    if (runningId){
                        const id = document.createElement('div');
                        id.style.marginTop = '4px';
                        id.style.fontFamily = 'var(--mono)';
                        id.style.fontSize = '11px';
                        id.style.color = 'rgba(232,240,255,.55)';
                        id.textContent = String(runningId).slice(0, 8) + '...';
                        td.appendChild(id);
                    }
                } else {
                    td.appendChild(makeTag('IDLE', 'good'));
                }

                tr.appendChild(td);
            }

            // last ok/fail + error
            {
                const td = document.createElement('td');
                td.className = 'c-last';

                const okTxt = lastOk ? `OK  ${fmtUtc(lastOk)}` : 'OK  -';
                const failTxt = lastFail ? `FAIL ${fmtUtc(lastFail)}` : 'FAIL -';

                const line1 = document.createElement('div');
                line1.style.color = 'rgba(46,229,157,.90)';
                line1.style.fontFamily = 'var(--mono)';
                line1.textContent = okTxt;

                const line2 = document.createElement('div');
                line2.style.color = lastFail ? 'rgba(255,102,122,.95)' : 'rgba(232,240,255,.45)';
                line2.style.fontFamily = 'var(--mono)';
                line2.textContent = failTxt;

                td.appendChild(line1);
                td.appendChild(line2);

                if (lastErr){
                    const err = document.createElement('div');
                    err.style.marginTop = '4px';
                    err.style.color = 'rgba(255,102,122,.95)';
                    err.style.fontFamily = 'var(--mono)';
                    err.style.fontSize = '11px';
                    err.style.whiteSpace = 'normal';
                    err.textContent = String(lastErr).slice(0, 140);
                    td.appendChild(err);
                }

                tr.appendChild(td);
            }

            // action (kept for future; currently blank)
            {
                const td = document.createElement('td');
                td.className = 'c-actions';
                td.innerHTML = '<span class="muted">-</span>';
                tr.appendChild(td);
            }

            body.appendChild(tr);
        }
    }

    // ============================
    // Refresh loop (skip while editing)
    // ============================
    function setLastTs(){
        document.getElementById('lastTs').textContent = nowHHMMSS();
    }

    async function tick(force){
        if (!force && pauseRefreshBecauseEditing) return;
        if (!backendBaseUrl) return;

        try{
            const [cfg, st] = await Promise.all([getConfig(), getStatus()]);
            lastConfig = cfg;
            lastStatus = st;
            setLastTs();

            if (typeof st.paused === 'boolean'){
                setEnginePill(st.paused ? 'paused' : 'running', st.paused ? 'paused' : 'running');
                setButtonsEnabled(st.paused);
            }

            if (!pauseRefreshBecauseEditing) render();
        }catch(ex){
            setEnginePill('error', 'error');
            logLine('err', `refresh error: ${ex.message}`);
        }
    }

    // ✅ single definition (ไม่มีซ้ำแล้ว)
    async function forceRefresh(){
        await tick(true);
    }

    function bindEditingGuards(){
        const wrap = document.getElementById('tableWrap');
        wrap.addEventListener('focusin', (e) => {
            const tag = (e.target && e.target.tagName) ? e.target.tagName.toLowerCase() : '';
            if (tag === 'input' || tag === 'textarea' || tag === 'select'){
                pauseRefreshBecauseEditing = true;
            }
        });
        wrap.addEventListener('focusout', (e) => {
            const tag = (e.target && e.target.tagName) ? e.target.tagName.toLowerCase() : '';
            if (tag === 'input' || tag === 'textarea' || tag === 'select'){
                setTimeout(() => { pauseRefreshBecauseEditing = false; }, 250);
            }
        });
    }

    async function forcerun(){
    if (!backendBaseUrl){
        logLine('err', 'forcerun: no backendBaseUrl');
        return;
    }

    try{
        // ส่ง now+3s ให้ backend (กัน clock skew เล็กน้อย)
        const dueUnixMs = Date.now() + 3000;

        await fetchJson(api('/admin/tasks/forcerun'), {
            method: 'POST',
            headers: { 'Content-Type':'application/json' },
            body: JSON.stringify({
                dueUnixMs,           // เป้าหมาย updated_at_unixms
                enabledOnly: true    // ชัดเจน: เฉพาะ enabled=1
            })
        });

        logLine('ok', `Force run requested: enabled=1, updated_at_unixms=${dueUnixMs} (now+3s)`);

        // refresh UI หลังสั่งงาน
        await forceRefresh();
    }catch(ex){
        logLine('err', `forcerun error: ${ex.message}`);
    }
}

    // ============================
    // Boot
    // ============================
    (async function boot(){
        clearConsole();
        logLine('ok', 'AdminPage loaded');

        try{
            await loadBackendConfig();
        }catch(ex){
            logLine('err', `backend-config error: ${ex.message}`);
            setEnginePill('error', 'no config');
            return;
        }

        bindEditingGuards();

        await tick(true);
        setInterval(() => tick(false), POLL_SEC * 1000);
    })();

    // ============================
    // Console filter (additive — does not modify any function above)
    // ============================
    (function initConsoleFilter(){
        const box    = document.getElementById('consoleBox');
        const badge  = document.getElementById('logCountBadge');
        const grp    = document.getElementById('filterGrp');
        if (!box || !badge || !grp) return;

        let activeFilter = 'all';

        // Map a .log-line element to its level string
        function lineLevel(el){
            if (el.querySelector('.log-ok'))   return 'ok';
            if (el.querySelector('.log-warn')) return 'warn';
            if (el.querySelector('.log-err'))  return 'err';
            return 'info';
        }

        // Show/hide a single line according to current filter
        function applyToLine(el){
            el.style.display =
                (activeFilter === 'all' || lineLevel(el) === activeFilter) ? '' : 'none';
        }

        // Reapply filter to all existing lines + update badge
        function applyFilter(){
            box.querySelectorAll('.log-line').forEach(applyToLine);
            badge.textContent = String(box.querySelectorAll('.log-line').length);
        }

        // Watch for new log lines and clear events
        const obs = new MutationObserver(() => {
            box.querySelectorAll('.log-line').forEach(applyToLine);
            badge.textContent = String(box.querySelectorAll('.log-line').length);
        });
        obs.observe(box, { childList: true });

        // Filter button clicks
        grp.querySelectorAll('.fb').forEach(btn => {
            btn.addEventListener('click', () => {
                grp.querySelectorAll('.fb').forEach(b => b.classList.remove('fb-active', 'active'));
                btn.classList.add('fb-active');
                activeFilter = btn.dataset.filter || 'all';
                applyFilter();
            });
        });
    })();

    // ============================
    // Regression Test Modal
    // ============================

    // ── Modal open / close ────────────────────────────────────────
    function openTestModal() {
        const modal = document.getElementById('testModal');
        modal.classList.remove('is-closing');           // clear any leftover exit state
        document.getElementById('testList').innerHTML      = '';
        document.getElementById('testSumText').textContent = 'Running…';
        document.getElementById('testProgFill').style.cssText = 'width:0%;background:rgba(90,211,109,.8)';
        const badge = document.getElementById('testSumBadge');
        badge.textContent = '';
        badge.className   = 'test-sum-badge';
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.documentElement.classList.add('bb-modal-open');
        document.body.classList.add('bb-modal-open');
    }

    function closeTestModal() {
        const modal = document.getElementById('testModal');
        if (!modal.classList.contains('is-open') || modal.classList.contains('is-closing')) return;
        modal.classList.add('is-closing');
        modal.setAttribute('aria-hidden', 'true');
        setTimeout(() => {
            modal.classList.remove('is-open', 'is-closing');
            const anyOpen = !!document.querySelector('.bb-modal-backdrop.is-open');
            document.documentElement.classList.toggle('bb-modal-open', anyOpen);
            document.body.classList.toggle('bb-modal-open', anyOpen);
            document.getElementById('btnRunTests').disabled = false;
        }, 200);
    }

    // Wire close button, footer close, backdrop click, Escape
    (function () {
        function init() {
            const modal        = document.getElementById('testModal');
            const closeBtn     = document.getElementById('testModalClose');
            const closeBtnFoot = document.getElementById('testModalCloseFooter');
            if (closeBtn)     closeBtn.addEventListener('click', closeTestModal);
            if (closeBtnFoot) closeBtnFoot.addEventListener('click', closeTestModal);
            if (modal)        modal.addEventListener('click', e => { if (e.target === modal) closeTestModal(); });
            document.addEventListener('keydown', e => {
                if (e.key === 'Escape' && document.getElementById('testModal')?.classList.contains('is-open'))
                    closeTestModal();
            });
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
        else init();
    })();

    // ── Progress helpers ──────────────────────────────────────────
    function updateTestProgress(passed, failed, total) {
        const pct  = total > 0 ? (passed / total * 100).toFixed(1) : 0;
        const fill = document.getElementById('testProgFill');
        fill.style.width      = pct + '%';
        fill.style.background = failed > 0 ? 'rgba(255,91,91,.8)' : 'rgba(90,211,109,.8)';
        document.getElementById('testSumText').textContent =
            total === 0 ? 'Running…' : `${passed} / ${total} passed`;
    }

    function finalizeTestProgress(passed, failed, total) {
        updateTestProgress(passed, failed, total);
        const allOk = failed === 0 && total > 0;
        const badge = document.getElementById('testSumBadge');
        badge.textContent = allOk ? '✓ All passed' : `✗ ${failed} failed`;
        badge.className   = 'test-sum-badge ' + (allOk ? 'ok' : 'fail');
    }

    // ── DOM helpers ───────────────────────────────────────────────
    function escH(s) {
        return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function addSectionHeader(label) {
        const el = document.createElement('div');
        el.className   = 'test-section-hdr';
        el.textContent = label;
        document.getElementById('testList').appendChild(el);
    }

    function addFetchError(label, msg) {
        const el = document.createElement('div');
        el.className   = 'test-fetch-err';
        el.textContent = `${label}: ${msg}`;
        document.getElementById('testList').appendChild(el);
    }

    function addTestItem(c) {
        const item = document.createElement('div');
        item.className = 'test-item ' + (c.passed ? 'pass' : 'fail');

        const icon  = document.createElement('span');
        icon.className   = 'test-icon';
        icon.textContent = c.passed ? '✓' : '✗';

        const name  = document.createElement('span');
        name.className   = 'test-name';
        name.textContent = c.name;

        const dur   = document.createElement('span');
        dur.className   = 'test-dur';
        dur.textContent = c.durationMs + ' ms';

        item.appendChild(icon);
        item.appendChild(name);
        item.appendChild(dur);

        if (!c.passed && c.error) {
            const err = document.createElement('span');
            err.className   = 'test-err-msg';
            err.textContent = c.error;
            item.appendChild(err);
        }

        document.getElementById('testList').appendChild(item);
    }

    // ── Core runner ───────────────────────────────────────────────
    async function renderSuite(label, cases, onEach) {
        addSectionHeader(label);
        for (const c of cases) {
            addTestItem(c);
            onEach(c.passed);
            await new Promise(r => setTimeout(r, 14)); // staggered reveal
        }
    }

    // ── E2E helpers ───────────────────────────────────────────────
    // ทุก test เรียก fetch() จริงจาก browser → BellBeast → (Uroboros)
    // ผล "pass" = ได้ HTTP status / body ที่คาดหวังจริง

    async function runE2ECase(name, fn) {
        const t0 = performance.now();
        try {
            await fn();
            return { name, passed: true, error: null,
                     durationMs: Math.round(performance.now() - t0) };
        } catch (e) {
            return { name, passed: false, error: e.message,
                     durationMs: Math.round(performance.now() - t0) };
        }
    }

    function e2eAssert(condition, message) {
        if (!condition) throw new Error(message ?? 'Assertion failed');
    }

    function e2eAssertStatus(expected, actual, path) {
        if (expected !== actual)
            throw new Error(`Expected HTTP ${expected} but got ${actual}  [${path}]`);
    }

    async function runTests() {
        document.getElementById('btnRunTests').disabled = true;
        openTestModal();

        let gPass = 0, gFail = 0, gTotal = 0;

        function tick(passed) {
            if (passed) gPass++; else gFail++;
            gTotal++;
            updateTestProgress(gPass, gFail, gTotal);
        }

        // ① BellBeast local — unit/config tests (no real HTTP, no engine)
        try {
            const resp = await fetch('/api/admin/test/run-local');
            if (resp.ok) {
                const r = await resp.json();
                await renderSuite('BellBeast', r.cases ?? [], tick);
            } else {
                addFetchError('BellBeast', `HTTP ${resp.status}`);
            }
        } catch (e) { addFetchError('BellBeast', e.message); }

        // ② BellBeast E2E — fetch() จริงจาก browser ไป BellBeast (ไม่ต้องการ engine)
        {
            const cases = [];

            // GET /api/backend-config
            cases.push(await runE2ECase('E2E | GET /api/backend-config → 200', async () => {
                const r = await fetch('/api/backend-config');
                e2eAssertStatus(200, r.status, '/api/backend-config');
            }));

            cases.push(await runE2ECase('E2E | GET /api/backend-config → Content-Type: application/json', async () => {
                const r = await fetch('/api/backend-config');
                const ct = r.headers.get('content-type') ?? '';
                e2eAssert(ct.includes('application/json'), `Got Content-Type: ${ct}`);
            }));

            cases.push(await runE2ECase('E2E | GET /api/backend-config → backendBaseUrl non-empty', async () => {
                const r = await fetch('/api/backend-config');
                const j = await r.json();
                e2eAssert(j.backendBaseUrl && j.backendBaseUrl.trim() !== '',
                    'backendBaseUrl must not be empty');
            }));

            cases.push(await runE2ECase("E2E | GET /api/backend-config → key 'queryCsvPath' present", async () => {
                const r = await fetch('/api/backend-config');
                const j = await r.json();
                e2eAssert('queryCsvPath' in j, "Missing key 'queryCsvPath'");
            }));

            cases.push(await runE2ECase("E2E | GET /api/backend-config → key 'wayfarerApiPath' present", async () => {
                const r = await fetch('/api/backend-config');
                const j = await r.json();
                e2eAssert('wayfarerApiPath' in j, "Missing key 'wayfarerApiPath'");
            }));

            // GET /api/admin/auth/me  (ส่ง cookie session จริงจาก browser)
            cases.push(await runE2ECase('E2E | GET /api/admin/auth/me → 200 (authenticated)', async () => {
                const r = await fetch('/api/admin/auth/me');
                e2eAssertStatus(200, r.status, '/api/admin/auth/me');
            }));

            cases.push(await runE2ECase('E2E | GET /api/admin/auth/me → body.ok === true', async () => {
                const r = await fetch('/api/admin/auth/me');
                const j = await r.json();
                e2eAssert(j.ok === true,
                    `Expected ok=true, got ok=${JSON.stringify(j.ok)}`);
            }));

            // POST /api/admin/enqueue — validation (ไม่แตะ engine)
            cases.push(await runE2ECase('E2E | POST /api/admin/enqueue (missing name) → 400', async () => {
                const r = await fetch('/api/admin/enqueue', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: '{}'
                });
                e2eAssertStatus(400, r.status, '/api/admin/enqueue');
            }));

            await renderSuite('BellBeast E2E', cases, tick);
        }

        // ③ Engine E2E — fetch() จริง ผ่าน BellBeast → Uroboros (ต้องการ engine online)
        //    pause → resume เพื่อ restore state; cancelall จะล้าง task ที่รันอยู่
        {
            const cases = [];

            cases.push(await runE2ECase('E2E | POST /api/admin/pause → 200', async () => {
                const r = await fetch('/api/admin/pause', { method: 'POST' });
                e2eAssertStatus(200, r.status, '/api/admin/pause');
            }));

            cases.push(await runE2ECase('E2E | POST /api/admin/resume → 200  (restores scheduler)', async () => {
                const r = await fetch('/api/admin/resume', { method: 'POST' });
                e2eAssertStatus(200, r.status, '/api/admin/resume');
            }));

            cases.push(await runE2ECase('E2E | POST /api/admin/cancelall → 200', async () => {
                const r = await fetch('/api/admin/cancelall', { method: 'POST' });
                e2eAssertStatus(200, r.status, '/api/admin/cancelall');
            }));

            await renderSuite('Engine E2E', cases, tick);
        }

        // ④ Task Last Run — ตรวจผลการทำงานล่าสุดของแต่ละ task จาก Uroboros
        //    ผ่านเมื่อ lastOkAtUtc ≥ lastFailAtUtc (หรือไม่มี fail เลย)
        {
            const TASK_NAMES = [
                'tps.refresh',        'dps.refresh',         'rws1.refresh',
                'rws2.refresh',       'chem1.refresh',       'chem2.refresh',
                'branch.refresh',     'rcv38.refresh',       'ptc.query.once',
                'onlinelab.query',    'Aquadat.refresh',     'AquadatFWS.refresh',
                'DB_upload.refresh',  'DB_download.refresh', 'MDB_upload.refresh',
                'MDB_download.refresh', 'LAB.import.daily'
            ];

            const cases = [];
            let statusRows = null;

            // ── ดึง status ครั้งเดียว ─────────────────────────────────────────
            cases.push(await runE2ECase(
                'Task Last Run | GET /api/admin/tasks/status → 200', async () =>
            {
                const r = await fetch('/api/admin/tasks/status');
                e2eAssertStatus(200, r.status, '/api/admin/tasks/status');
                const j = await r.json();
                statusRows = j.tasks ?? j;
                e2eAssert(Array.isArray(statusRows) && statusRows.length > 0,
                    'Expected non-empty tasks array');
            }));

            // ── 1 test ต่อ task ───────────────────────────────────────────────
            const byName = statusRows
                ? Object.fromEntries(statusRows.map(r => [(r.name ?? '').toLowerCase(), r]))
                : {};

            for (const name of TASK_NAMES) {
                const n = name;
                cases.push(await runE2ECase(`Task Last Run | ${n}`, async () => {
                    if (!statusRows)
                        throw new Error('tasks/status unavailable — engine may be offline');

                    const row = byName[n.toLowerCase()];
                    e2eAssert(row !== undefined,
                        `'${n}' not found in status (not registered?)`);
                    e2eAssert(row.lastOkAtUtc != null,
                        `'${n}' has never completed OK`);

                    const okMs   = new Date(row.lastOkAtUtc).getTime();
                    const failMs = row.lastFailAtUtc ? new Date(row.lastFailAtUtc).getTime() : 0;
                    e2eAssert(okMs >= failMs,
                        `Last run FAIL at ${row.lastFailAtUtc}` +
                        (row.lastError ? ` — ${row.lastError}` : ''));
                }));
            }

            await renderSuite('Task Last Run', cases, tick);
        }

        // ⑤ Uroboros engine self-tests (requires live engine)
        try {
            const resp = await fetch('/api/admin/test/run');
            if (resp.ok) {
                const r = await resp.json();
                await renderSuite('Uroboros', r.cases ?? [], tick);
            } else {
                addFetchError('Uroboros', `HTTP ${resp.status} — engine may be offline`);
            }
        } catch (e) { addFetchError('Uroboros', `${e.message} — engine may be offline`); }

        finalizeTestProgress(gPass, gFail, gTotal);
        // also echo a one-liner to the engine console
        logLine(gFail === 0 ? 'ok' : 'err',
            `[Tests] ${gPass}/${gTotal} passed, ${gFail} failed`);
    }
</script>

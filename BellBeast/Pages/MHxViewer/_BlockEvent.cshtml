<style>
    section.event-block .bb-section-b {
        margin: 5px;
        padding-right: 10px;
        height: 380px;
        box-sizing: border-box;
    }

    section.event-block .event-grid {
        display: grid;
        grid-template-columns: 30% 70%;
        gap: 10px;
        align-items: stretch;
        height: 100%;
        box-sizing: border-box;
        min-width: 0;
    }

    @@media (max-width: 1100px) {
        section.event-block .event-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ===== LEFT PANEL ===== */
    section.event-block .event-panel {
        background: rgba(255,255,255,.04);
        border: 1px solid var(--stroke);
        border-radius: 10px;
        padding: 10px;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        min-width: 0;
        min-height: 0;
    }

    section.event-block .chem-event-list {
        display: grid;
        gap: 10px;
        margin-top: 10px;
    }

    section.event-block .chem-row {
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 10px;
        padding: 0 6px 0 5px;
        min-height: 105px;
        box-sizing: border-box;
        display: grid;
        grid-template-columns: 74px 1fr;
        gap: 8px;
        align-items: center;
    }

    section.event-block .chem-left {
        display: flex;
        align-items: center;
        justify-content: flex-start;
    }

    section.event-block .chem-tag {
        min-width: 68px;
        height: 28px;
        padding: 0 8px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .3px;
        border: 1px solid rgba(0,0,0,.20);
        color: rgba(255,255,255,.95);
        white-space: nowrap;
    }

        section.event-block .chem-tag.alum {
            background: rgba(95,228,255,.18);
        }

        section.event-block .chem-tag.pacl {
            background: rgba(255,204,77,.18);
        }

        section.event-block .chem-tag.chlorine {
            background: rgba(90,211,109,.18);
        }

    section.event-block .chem-right {
        display: grid;
        gap: 8px;
        align-content: center;
        min-width: 0;
    }

    section.event-block .chem-line {
        display: grid;
        grid-template-columns: 46px minmax(64px, 1fr) auto;
        column-gap: 8px;
        align-items: baseline;
        line-height: 1.15;
        min-width: 0;
    }

        section.event-block .chem-line .k {
            font-size: 13px;
            font-weight: 800;
            color: rgba(255,255,255,.92);
            white-space: nowrap;
        }

        section.event-block .chem-line .v {
            font-size: 14px;
            font-weight: 900;
            color: #5fe4ff;
            text-align: right;
            white-space: nowrap;
            font-variant-numeric: tabular-nums;
        }

        section.event-block .chem-line .chem-unit {
            font-size: 13px;
            font-weight: 800;
            color: rgba(255,255,255,.78);
            white-space: nowrap;
        }

    /* ===== RIGHT STORAGE GRID ===== */
    section.event-block .storage-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        column-gap: 10px;
        row-gap: 6px;
        height: 100%;
        min-width: 0;
        box-sizing: border-box;
        align-content: start;
        grid-auto-rows: max-content;
    }

    section.event-block .storage-colhead {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 16px;
        padding: 0;
        margin: 0;
        font-size: 12px;
        font-weight: 900;
        color: rgba(255,255,255,.92);
        letter-spacing: .2px;
        line-height: 1;
    }

    section.event-block .storage-gauge-card {
        align-self: start;
        height: 160px;
        min-height: 160px;
        box-sizing: border-box;
    }

        section.event-block .storage-gauge-card.dual {
            height: 140px;
            min-height: 140px;
        }

    section.event-block .tank-pair {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
        height: 100%;
    }

    section.event-block .tank-slot {
        display: flex;
        flex-direction: column;
        min-width: 0;
        height: 100%;
    }

    section.event-block .tank-name {
        height: 16px;
        margin-bottom: 4px;
        font-size: 10px;
        font-weight: 900;
        color: rgba(255,255,255,.84);
        text-align: center;
        line-height: 1;
        letter-spacing: .25px;
    }

    section.event-block .tank-slot .chem-tank {
        flex: 1;
        min-height: 0;
    }

    section.event-block .storage-delta-card {
        align-self: start;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 10px;
        padding: 4px 8px;
        box-sizing: border-box;
        min-width: 0;
        min-height: 30px;
        display: grid;
        grid-template-columns: 1fr auto auto;
        column-gap: 8px;
        align-items: center;
        margin: 0;
    }

    section.event-block .storage-delta-title {
        font-size: 11px;
        font-weight: 900;
        color: rgba(255,255,255,.72);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-align: left;
        line-height: 1;
    }

    section.event-block .storage-delta-value {
        font-size: 16px;
        font-weight: 900;
        color: #5fe4ff;
        font-variant-numeric: tabular-nums;
        line-height: 1;
        white-space: nowrap;
        text-align: right;
    }

    section.event-block .storage-delta-unit {
        font-size: 11px;
        font-weight: 800;
        color: rgba(255,255,255,.68);
        white-space: nowrap;
        text-align: left;
        line-height: 1;
    }

    /* ===== GAUGE / TANK ===== */
    section.event-block .chem-tank {
        display: flex;
        flex-direction: column;
        gap: 0;
        min-width: 0;
        height: 100%;
    }

        section.event-block .chem-tank.alum {
            --tank-fill-top: rgba(108, 226, 255, .92);
            --tank-fill-bottom: rgba(53, 151, 255, .82);
        }

        section.event-block .chem-tank.pacl {
            --tank-fill-top: rgba(255, 214, 102, .92);
            --tank-fill-bottom: rgba(214, 155, 44, .84);
        }

        section.event-block .chem-tank.chlorine {
            --tank-fill-top: rgba(110, 231, 140, .92);
            --tank-fill-bottom: rgba(46, 176, 92, .84);
        }

    section.event-block .chem-well {
        position: relative;
        height: 100%;
        border-radius: 14px;
        background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01)), rgba(10,16,24,.92);
        border: 1px solid rgba(255,255,255,.12);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.04), inset 0 10px 24px rgba(255,255,255,.02), 0 4px 14px rgba(0,0,0,.18);
        overflow: hidden;
    }

    section.event-block .chem-fill {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: calc(var(--fill, 0) * 1%);
        background: linear-gradient( 180deg, var(--tank-fill-top, rgba(108,226,255,.90)) 0%, var(--tank-fill-bottom, rgba(53,151,255,.82)) 100% );
        opacity: .96;
        transition: height .35s ease;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.25), 0 0 14px rgba(255,255,255,.05);
    }

        section.event-block .chem-fill::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient( 180deg, rgba(255,255,255,.18) 0%, rgba(255,255,255,.06) 18%, rgba(255,255,255,0) 40% );
            pointer-events: none;
        }

    section.event-block .chem-midnight {
        position: absolute;
        left: 8%;
        right: 8%;
        bottom: calc(var(--midnight, 0) * 1%);
        height: 0;
        border-top: 2px dashed rgba(255,255,255,.95);
        opacity: 1;
        pointer-events: none;
        filter: drop-shadow(0 0 2px rgba(0,0,0,.45));
    }

    section.event-block .chem-read {
        position: absolute;
        left: 50%;
        top: 52%;
        transform: translate(-50%, -50%);
        min-width: 78%;
        max-width: 90%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        color: rgba(255,255,255,.98);
        text-shadow: 0 1px 2px rgba(0,0,0,.55);
        font-size: 13px;
        text-align: center;
        padding: 6px 8px;
        line-height: 1.2;
        z-index: 3;
        border-radius: 10px;
        background: rgba(7, 12, 18, .28);
        backdrop-filter: blur(1.5px);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.06), 0 2px 8px rgba(0,0,0,.14);

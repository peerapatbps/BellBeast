<section class="bb-section">
    <div class="bb-section-h">
        <div class="left"><div style="font-size:12px;opacity:.9">CWS - FWS1</div></div>
        <div class="bb-bell">🔔</div>
    </div>

    <div class="bb-section-b">
        <div class="matrix">
            <div class="leftbox">
                <div class="row"><span>Unit 1A</span><span class="tagpill a">99</span></div>
                <div class="row"><span>Suction</span><span>xx s.</span></div>
                <div class="row"><span>Flush</span><span>xx s.</span></div>
                <div class="row"><span>Unit 1B</span><span class="tagpill a">99</span></div>
                <div class="row"><span>Unit 2A</span><span class="tagpill c">99</span></div>
                <div class="row"><span>Unit 2B</span><span class="tagpill c">99</span></div>
            </div>

            <div>
                <div class="units">
                    <div class="u ok">1</div><div class="u ok">2</div><div class="u ok">3</div><div class="u ok">4</div><div class="u ok">5</div><div class="u ok">6</div><div class="u ok">7</div>
                    <div class="u ok">8</div><div class="u ok">9</div><div class="u ok">10</div><div class="u warn">11</div><div class="u ok">12</div><div class="u ok">13</div><div class="u bad">14</div>
                </div>

                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px; align-items:stretch;">
                    <div class="mini-card" style="min-height:140px;">
                        <div class="lab">CW#1 TURBID</div>
                        <div class="chart">[chart]</div>
                    </div>
                    <div class="mini-card" style="min-height:140px;">
                        <div class="lab">CW#2 TURBID</div>
                        <div class="chart">[chart]</div>
                    </div>
                </div>
            </div>

            <div>
                <div class="mini-card" style="min-height:140px;">
                    <div class="lab">TW#1 TURBID</div>
                    <div class="chart">[chart]</div>
                </div>
                <div class="mini-card" style="margin-top:10px; min-height:140px;">
                    <div class="lab">TW#2 TURBID</div>
                    <div class="chart">[chart]</div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .mini-card .chart {
        position: relative;
        height: 110px;
        min-height: 110px;
        border-radius: 10px;
        border: 1px dashed rgba(255,255,255,.18);
        background: rgba(255,255,255,.04);
        overflow: hidden;
    }

        .mini-card .chart canvas {
            width: 100% !important;
            height: 100% !important;
            display: block !important;
        }

    .mini-card .mini-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0px;
        margin-bottom: -5px;
    }

    /* ===== FIX: ปุ่ม Settings ต้องกดได้แน่ (กันโดนชั้นอื่นทับ) ===== */
    section.rws-block .bb-section-h,
    section.rws-block .bb-section-h .right-icons {
        position: relative;
        z-index: 99999 !important;
        pointer-events: auto !important;
    }

    section.rws-block #rwsBtnSettings,
    section.rws-block .bb-ico {
        position: relative;
        z-index: 100000 !important;
        pointer-events: auto !important;
    }
</style>


            </div>

            <div class="mini-card r2c4">
                <div class="ov-top"><div class="ov-title">RW DO (mg/L)</div><div class="ov-status ok" id="rwsDoStatus">OK</div></div>
                <div class="chart"><canvas id="RW_DO"></canvas></div>
            </div>

            <div class="mini-card r2c5">
                <div class="ov-top"><div class="ov-title">RW TEMP (°C)</div><div class="ov-status ok" id="rwsTempStatus">OK</div></div>
                <div class="chart"><canvas id="RW_TEMP"></canvas></div>
            </div>

        </div>

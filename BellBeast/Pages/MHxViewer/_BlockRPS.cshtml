                <div class="pump"><span class="tag">1P01B</span><span class="st stby" data-pump="1P01B">-</span></div>
                <div class="pump"><span class="tag">1P01C</span><span class="st stby" data-pump="1P01C">-</span></div>
                <div class="pump"><span class="tag">1P02A</span><span class="st stby" data-pump="1P02A">-</span></div>
                <div class="pump"><span class="tag">1P02B</span><span class="st stby" data-pump="1P02B">-</span></div>
            </div>

            <div class="kpi small r1c2">
                <div class="ov-top">
                    <div class="ov-title">RW#1 (m³/h)</div>
                    <div class="ov-status ok" id="rwsFlow1Status">OK</div>
                </div>
                <div class="val-center" id="rwsFlow1">-</div>
                <div class="sub"><span>ΣFLOW1</span><span id="rwsSum1">-</span><span class="ov-unit">m³/day</span></div>
            </div>

            <div class="kpi small r1c3">
                <div class="ov-top">
                    <div class="ov-title">RW#2 (m³/h)</div>
                    <div class="ov-status ok" id="rwsFlow2Status">OK</div>
                </div>
                <div class="val-center" id="rwsFlow2">-</div>
                <div class="sub"><span>ΣFLOW2</span><span id="rwsSum2">-</span><span class="ov-unit">m³/day</span></div>
            </div>

            <div class="mini-card r1c4">
                <div class="ov-top"><div class="ov-title">RW TURBID (NTU)</div><div class="ov-status ok" id="rwsNtuStatus">OK</div></div>
                <div class="chart"><canvas id="RW_NTU"></canvas></div>
            </div>

            <div class="mini-card r1c5">
                <div class="ov-top"><div class="ov-title">RW COND (μS/cm)</div><div class="ov-status ok" id="rwsCondStatus">OK</div></div>
                <div class="chart"><canvas id="RW_COND"></canvas></div>
            </div>

            <!-- =======================
                 RWS2 pumps
            ======================== -->
            <div class="pump-col r2">
                <div class="pump"><span class="tag">Pump1</span><span class="st stby" data-pump="Pump1">-</span></div>
                <div class="pump"><span class="tag">Pump2</span><span class="st stby" data-pump="Pump2">-</span></div>
                <div class="pump"><span class="tag">Pump3</span><span class="st stby" data-pump="Pump3">-</span></div>
                <div class="pump"><span class="tag">Pump4</span><span class="st stby" data-pump="Pump4">-</span></div>
                <div class="pump"><span class="tag">Pump5</span><span class="st stby" data-pump="Pump5">-</span></div>
            </div>

            <div class="kpi small r2c2">
                <div class="ov-top">
                    <div class="ov-title">RW#3 (m³/h)</div>
                    <div class="ov-status ok" id="rwsFlow3Status">OK</div>
                </div>
                <div class="val-center" id="rwsFlow3">-</div>
                <div class="sub"><span>ΣFLOW3</span><span id="rwsSum3">-</span><span class="ov-unit">m³/day</span></div>
            </div>

            <div class="kpi small r2c3">
                <div class="ov-top">
                    <div class="ov-title">RW#4 (m³/h)</div>

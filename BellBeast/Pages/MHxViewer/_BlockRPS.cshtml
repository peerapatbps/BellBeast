         data-rws-refresh-sec="5"
         data-rws-pumps='{"1P01A":10,"1P01B":15,"1P01C":20,"1P02A":25,"1P02B":29,"Pump1":46,"Pump2":52,"Pump3":58,"Pump4":63,"Pump5":69}'
         data-rws-metrics='{"flow1":"rwp1_flowp1","flow2":"rwp1_flowp2","sum1":"rwp1_sumflowp1","sum2":"rwp1_sumflowp2","flow3":"rwp2_flowp3","flow4":"rwp2_flowp4","sum3":"rwp2_sumflowp3","sum4":"rwp2_sumflowp4"}'>


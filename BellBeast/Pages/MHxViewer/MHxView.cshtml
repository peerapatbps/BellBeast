<script>
    // เรียกอันเดียวจบ (รองรับทั้งโหลดหน้า + inject partial)
    window.MHxCharts = {
      initWithin: function (root) {
        try { window.BBTrend?.initWithin(root); } catch (e) {}
        try { window.DPSView?.initWithin(root); } catch (e) {}
        try { window.RWSView?.initWithin(root); } catch (e) {}
        try { window.RWSOnlineSettings?.initWithin(root); } catch (e) {}
        try { window.CHEMView?.initWithin(root); } catch (e) {}
        try { window.EVENTsettings?.initWithin(root); } catch (e) {}
        try { window.EVENTView?.initWithin(root); } catch (e) {}
        try { window.DPSSmartmapOverlay?.initWithin(root); } catch (e) {}
        try { window.BBTrendPTC?.initWithin(root); } catch (e) {}

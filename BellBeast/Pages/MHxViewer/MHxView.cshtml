<script>
    document.addEventListener("DOMContentLoaded", function () {
        const FEEDBACK_FORM_RESPONSE_URL = "https://docs.google.com/forms/d/e/1FAIpQLSehDe6NXz1pBqv6T-Fzti1af_Nu_EjZz286NQ6IVYBxpbOXUw/formResponse";
        const FEEDBACK_ENTRY = {
            rating: "entry.1902867980",
            message: "entry.310717710",
            contact: "entry.1371650762"
        };

        const btnOpen = document.getElementById("btnFeedback");
        const modal = document.getElementById("feedbackModal");
        const btnClose = document.getElementById("feedbackModalClose");
        const btnCancel = document.getElementById("feedbackCancel");
        const btnSubmit = document.getElementById("feedbackSubmit");
        const ratingWrap = document.getElementById("feedbackRating");
        const ratingClear = document.getElementById("feedbackRatingClear");
        const messageInput = document.getElementById("feedbackMessage");
        const contactInput = document.getElementById("feedbackContact");
        const errorBox = document.getElementById("feedbackError");
        const statusBox = document.getElementById("feedbackStatus");

        if (!btnOpen || !modal || !messageInput || !contactInput || !btnSubmit) return;

        let selectedRating = null;
        let iframeLoadedOnce = false;
        let pendingSubmit = false;

        function setFeedbackModalOpen(isOpen) {
            modal.classList.toggle("is-open", isOpen);
            modal.setAttribute("aria-hidden", isOpen ? "false" : "true");

            const anyModalOpen = isOpen || !!document.querySelector(".bb-modal-backdrop.is-open");
            document.documentElement.classList.toggle("bb-modal-open", anyModalOpen);
            document.body.classList.toggle("bb-modal-open", anyModalOpen);

            if (isOpen) {
                setTimeout(() => messageInput.focus(), 50);
            }
        }

        function setStatus(message, kind) {
            if (!statusBox) return;
            statusBox.textContent = message || "";
            statusBox.classList.toggle("is-open", !!message);
            statusBox.classList.toggle("ok", kind === "ok");
            statusBox.classList.toggle("warn", kind === "warn");
        }

        function openFeedbackModal() {
            errorBox?.classList.remove("is-open");
            setStatus("", "");
            setFeedbackModalOpen(true);
        }

        function closeFeedbackModal() {
            if (pendingSubmit) return;
            setFeedbackModalOpen(false);
        }

        function setRating(value) {
            selectedRating = value == null ? null : Number(value);

            ratingWrap?.querySelectorAll(".bb-rating-btn").forEach(btn => {
                btn.classList.toggle("is-active", Number(btn.dataset.rating) === selectedRating);
            });
        }

        function getOrCreateSubmitIframe() {
            const iframeName = "feedbackSubmitFrame";
            let iframe = document.querySelector(`iframe[name="${iframeName}"]`);

            if (!iframe) {
                iframe = document.createElement("iframe");
                iframe.name = iframeName;
                iframe.style.display = "none";
                iframe.setAttribute("aria-hidden", "true");
                iframe.addEventListener("load", () => {
                    if (!iframeLoadedOnce) {
                        iframeLoadedOnce = true;
                        return;
                    }

                    if (!pendingSubmit) return;

                    pendingSubmit = false;
                    btnSubmit.disabled = false;
                    btnSubmit.textContent = "Send";
                    setStatus("ส่ง feedback แล้ว", "ok");

                    messageInput.value = "";
                    contactInput.value = "";
                    setRating(null);

                    setTimeout(() => {
                        setStatus("", "");
                        setFeedbackModalOpen(false);
                    }, 900);
                });
                document.body.appendChild(iframe);
            }

            return iframeName;
        }

        function appendHiddenInput(form, name, value) {
            const input = document.createElement("input");
            input.type = "hidden";
            input.name = name;
            input.value = value;
            form.appendChild(input);
        }

        function submitFeedback() {
            const message = (messageInput.value || "").trim();
            const contact = (contactInput.value || "").trim();

            if (!message) {
                errorBox?.classList.add("is-open");
                setStatus("", "");
                messageInput.focus();
                return;
            }

            errorBox?.classList.remove("is-open");
            setStatus("กำลังส่ง feedback...", "warn");

            pendingSubmit = true;
            btnSubmit.disabled = true;
            btnSubmit.textContent = "Sending...";

            const iframeName = getOrCreateSubmitIframe();

            const form = document.createElement("form");
            form.method = "POST";
            form.action = FEEDBACK_FORM_RESPONSE_URL;
            form.target = iframeName;
            form.style.display = "none";
            form.acceptCharset = "UTF-8";

            if (selectedRating !== null && selectedRating >= 1 && selectedRating <= 5) {
                appendHiddenInput(form, FEEDBACK_ENTRY.rating, String(selectedRating));
            }

            appendHiddenInput(form, FEEDBACK_ENTRY.message, message);
            appendHiddenInput(form, FEEDBACK_ENTRY.contact, contact);

            document.body.appendChild(form);
            form.submit();
            setTimeout(() => form.remove(), 1500);

            // Safety fallback: บาง browser/privacy mode ไม่ส่ง event load กลับมาจาก Google Form
            setTimeout(() => {
                if (!pendingSubmit) return;
                pendingSubmit = false;
                btnSubmit.disabled = false;
                btnSubmit.textContent = "Send";
                setStatus("ส่งคำขอแล้ว แต่ browser ไม่คืนสถานะยืนยันจาก Google Form", "warn");
            }, 4500);
        }

        btnOpen.addEventListener("click", openFeedbackModal);
        btnOpen.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
                e.preventDefault();
                openFeedbackModal();
            }
        });

        btnClose?.addEventListener("click", closeFeedbackModal);
        btnCancel?.addEventListener("click", closeFeedbackModal);
        btnSubmit.addEventListener("click", submitFeedback);

        ratingWrap?.addEventListener("click", (e) => {
            const btn = e.target.closest("[data-rating]");
            if (!btn) return;
            setRating(btn.dataset.rating);
        });

        ratingClear?.addEventListener("click", () => setRating(null));

        messageInput.addEventListener("input", () => {
            if ((messageInput.value || "").trim()) {
                errorBox?.classList.remove("is-open");
            }
            setStatus("", "");
        });

        modal.addEventListener("click", (e) => {
            if (e.target === modal) closeFeedbackModal();
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && modal.classList.contains("is-open")) {
                closeFeedbackModal();
            }
        });
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const STORAGE_KEY = "bb.main.slots.v1";

        const grid = document.getElementById("slotGrid");
        if (!grid) return;

        const btnOpen   = document.getElementById("btnSettings");
        const modal     = document.getElementById("slotModal");
        const btnClose  = document.getElementById("slotModalClose");
        const btnCancel = document.getElementById("slotCancel");
        const btnSave   = document.getElementById("slotSave");
        const btnReset  = document.getElementById("slotReset");
        const editor    = document.getElementById("slotEditor");

        const BLOCKS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(blocks.Select(x => new { key = x.key, label = x.label })));
        const DEFAULT_SLOTS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(defaultSlots));
        const VALID_SLOT_KEYS = new Set(BLOCKS.map(x => String(x.key).trim().toUpperCase()));

        function normalizeSlotKey(value){
            const key = value == null ? "" : String(value).trim().toUpperCase();
            if (!key || key === "0" || !VALID_SLOT_KEYS.has(key)) return "EMPTY";
            return key;
        }

        function normalize(arr){
            const base = [...DEFAULT_SLOTS];
            for (let i = 0; i < base.length; i++){
                base[i] = normalizeSlotKey(arr && arr[i]);
            }
            return base;
        }

        function loadSlots(){
            try {
                const raw = localStorage.getItem(STORAGE_KEY);
                if (!raw) return [...DEFAULT_SLOTS];
                const arr = JSON.parse(raw);
                if (!Array.isArray(arr)) return [...DEFAULT_SLOTS];
                return normalize(arr);
            } catch {
                return [...DEFAULT_SLOTS];
            }
        }

        function saveSlots(arr){
            localStorage.setItem(STORAGE_KEY, JSON.stringify(arr));
        }

        // ============================
        // ✅ โหลด partial ลงแต่ละช่อง (ซ้ำกันได้)
        // ============================
        async function renderSlotsFromLayout(layout){
            const slots = Array.from(grid.querySelectorAll(".bb-slot"));
            for (let i = 0; i < slots.length; i++){
                const key = normalizeSlotKey(layout[i]);

                // ✅ URL ชัวร์ ไม่เดา path: SLOT_URL ถูก gen โดย Razor
                const url = `${SLOT_URL}&key=${encodeURIComponent(key)}`;

                try{
                    const resp = await fetch(url, { method:"GET", credentials:"same-origin" });
                    const html = await resp.text();

                    // MHxView.cshtml : แก้ใน renderSlotsFromLayout() ตรงหลัง innerHTML
                    slots[i].innerHTML = html;
                    slots[i].setAttribute("data-key", key);

                    // init ทุกชนิดที่อาจอยู่ใน slot
                try { window.BBTrend?.initWithin(slots[i]); } catch(e){ console.warn("BBTrend init fail", e); }
                try { window.DPSView?.initWithin(slots[i]); } catch(e){ console.warn("DPSView init fail", e); }
                try { window.RWSView?.initWithin(slots[i]); } catch(e){ console.warn("RWSView init fail", e); }
                try { window.RWSOnlineSettings?.initWithin(slots[i]); } catch(e){ console.warn("RWSoverlay init fail", e); }
                try { window.CHEMView?.initWithin(slots[i]); } catch(e){ console.warn("CHEMView init fail", e); }
                try { window.EVENTsettings?.initWithin(slots[i]); } catch(e){ console.warn("EVENTViewsetting init fail", e); }
                try { window.EVENTView?.initWithin(slots[i]); } catch(e){ console.warn("EVENTView init fail", e); }
                try { window.BBTrendPTC?.initWithin(slots[i]); } catch(e){ console.warn("BBTrendPTC init fail", e); }
                try { window.DPSSmartmapOverlay?.initWithin(slots[i]); } catch(e){ console.warn("DPSSmartmapOverlay init fail", e); }
                try { window.PTCSmartmapOverlay?.initWithin(slots[i]); } catch(e){ console.warn("PTCSmartmapOverlay init fail", e); }
                try { window.PTCSmartmapOverlay?.tickAll?.(); } catch(e){ console.warn("PTCSmartmapOverlay tickAll fail", e); }
                try { window.DPSSummary?.initWithin(slots[i]); } catch(e){ console.warn("DPSSummary init fail", e); }
                try { window.TPSsettings?.initWithin(slots[i]); } catch(e){ console.warn("TPS setting init fail", e); }
                try { window.TPSSummary?.initWithin(slots[i]); } catch(e){ console.warn("TPSSummary init fail", e); }
                try { window.RWSSummary?.initWithin(slots[i]); } catch(e){ console.warn("RWSSummary init fail", e); }
                try { window.CHEMSummary?.initWithin(slots[i]); } catch(e){ console.warn("CHEMSummary init fail", e); }
                try { window.CHEMsettings?.initWithin(slots[i]); } catch(e){ console.warn("CHEM setting init fail", e); }
                try { window.LABView?.initWithin(slots[i]); } catch(e){ console.warn("LABView init fail", e); }
                try { window.CLDetectorView?.initWithin(slots[i]); } catch(e){ console.warn("CLDetector init fail", e); }
                try { window.CLDetectorSettings?.initWithin(slots[i]); } catch(e){ console.warn("CLDetector setting init fail", e); }

                }catch(err){
                    slots[i].innerHTML =
                      `<div class="bb-section">
                         <div class="bb-section-h">
                           <div class="left">${key}</div>
                           <div class="bb-bell">⚠️</div>
                         </div>
                         <div class="bb-section-b">Load failed</div>
                       </div>`;
                }
            }
        }

        // ✅ โหลดครั้งแรกตอนเปิดหน้า
        renderSlotsFromLayout(loadSlots());

        // ============================
        // ✅ Modal UI (ของเดิม)
        // ============================
        if (!btnOpen || !modal || !editor) return;

        function openModal(){
            modal.classList.add("is-open");
            modal.setAttribute("aria-hidden", "false");
            document.documentElement.classList.add("bb-modal-open");
            document.body.classList.add("bb-modal-open");
            renderEditor(loadSlots());
        }

        function closeModal(){
            modal.classList.remove("is-open");
            modal.setAttribute("aria-hidden", "true");
            document.documentElement.classList.remove("bb-modal-open");
            document.body.classList.remove("bb-modal-open");
        }

        function renderEditor(slots){
            editor.innerHTML = "";

            for (let i = 0; i < slots.length; i++){
                const wrap = document.createElement("div");
                wrap.className = "slot-card";

                const hdr = document.createElement("div");
                hdr.className = "hdr";

                const name = document.createElement("div");
                name.className = "name";
                name.textContent = `Slot ${i+1}`;

                const sel = document.createElement("select");
                sel.className = "bb-dd";
                sel.setAttribute("data-slot-index", String(i));

                for (const b of BLOCKS){
                    const opt = document.createElement("option");
                    opt.value = b.key;
                    opt.textContent = b.label;

                    const key = normalizeSlotKey(b.key);
                    if (key === normalizeSlotKey(slots[i])) opt.selected = true;

                    sel.appendChild(opt);
                }

                sel.addEventListener("change", () => {
                    slots[i] = normalizeSlotKey(sel.value);
                    editor._draftSlots = [...slots];
                });

                hdr.appendChild(name);
                hdr.appendChild(sel);

                const hint = document.createElement("div");
                hint.className = "hint";
                hint.textContent = "เลือก block ที่จะอยู่ในช่องนี้ (ซ้ำกันได้)";

                wrap.appendChild(hdr);
                wrap.appendChild(hint);
                editor.appendChild(wrap);
            }

            editor._draftSlots = [...slots];
        }

        btnOpen.addEventListener("click", openModal);
        btnClose && btnClose.addEventListener("click", closeModal);
        btnCancel && btnCancel.addEventListener("click", closeModal);

        modal.addEventListener("click", (e) => {
            if (e.target === modal) closeModal();
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && modal.classList.contains("is-open")) closeModal();
        });

        btnReset && btnReset.addEventListener("click", () => {
            renderEditor([...DEFAULT_SLOTS]);
        });

        btnSave && btnSave.addEventListener("click", async () => {
            const draft = editor._draftSlots || loadSlots();
            saveSlots(draft);
            closeModal();

            setTimeout(() => {
                window.location.reload();
            }, 50);
        });

    });
</script>


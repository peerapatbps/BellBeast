@page
@model BellBeast.Pages.MHxViewModel
@{
    ViewData["Title"] = "Main";

    // ✅ รายชื่อ block ที่คุณมีจริง (ปรับชื่อให้ตรงของคุณ)
    // ถ้าคุณมี 8 ช่อง ก็ใส่ 8 ตัว
    var defaultSlots = new[] { "TPS", "DPS", "RPS", "CHEM", "EVENT", "LAB", "CLDETECTOR", "PTC" };

    // ✅ สำหรับ dropdown ใน modal
    // label จะโชว์ในหน้าตั้งค่า
    var blocks = new (string key, string label)[] {
        ("EVENT", "Daily Events"),
        ("TPS", "TPS"),
        ("DPS", "DPS"),
        ("RPS", "RPS"),
        ("CHEM", "CHEM"),
        ("PTC", "PTC"),
        ("LAB", "LAB"),
        ("CLDETECTOR", "CL Detector"),
        ("EMPTY","(EMPTY)")
    };

    // ✅ helper: render slot content (ให้คุณชี้ไป partial ของคุณ)
    Func<string, object> RenderSlot = (key) =>
    {
        // ตัวอย่าง:
        // return Html.Partial($"~/Pages/MHxViewer/_Slot_{key}.cshtml");
        // หรือใช้ _SlotRenderer.cshtml แบบเดิมของคุณ
        return Html.Partial($"~/Pages/MHxViewer/_SlotRenderer.cshtml", key);
    };
}

<style>
    /* ===== Base ===== */
    :root {
        --bg: #1f2326;
        --panel: #2a2f33;
        --card: #2f353a;
        --card2: #2b3136;
        --stroke: rgba(255,255,255,.10);
        --muted: rgba(255,255,255,.65);
        --text: rgba(255,255,255,.92);
        --green: #5ad36d;
        --red: #ff5b5b;
        --amber: #ffcc4d;
        --cyan: #33d1ff;
    }

    html, body {
        height: 100%;
    }

    body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, -apple-system, Segoe UI, Roboto, "Noto Sans Thai", sans-serif;
        overflow-x: hidden;
    }

    /* ถ้ามี bootstrap container ครอบอยู่ ให้ยกเลิกให้หมด */
    .container, .container-fluid, .container-sm, .container-md,
    .container-lg, .container-xl, .container-xxl {
        width: 100% !important;
        max-width: none !important;
        margin: 0 !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
    }

    main, .main, .main-content, #mainContent {
        width: 100% !important;
        max-width: none !important;
        margin: 0 !important;
        padding: 0 !important;
    }

    /* ===== Topbar ===== */
    .bb-topbar {
        height: 44px;
        background: #5c8f4a;
        display: flex;
        align-items: center;
        padding: 0 12px;
        border-bottom: 1px solid rgba(0,0,0,.25);
    }

        .bb-topbar .hamb {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            background: rgba(255,255,255,.18);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .bb-topbar .title {
            margin-left: 10px;
            font-weight: 800;
            letter-spacing: .3px;
        }

        .bb-topbar .right {
            margin-left: auto;
            display: flex;
            gap: 10px;
            align-items: center;
        }

    .bb-ico {
        width: 30px;
        height: 30px;
        border-radius: 10px;
        background: rgba(255,255,255,.20);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(0,0,0,.15);
        cursor: pointer; /* ✅ เปลี่ยนเมาส์เป็นรูปมือ */
        transition: transform .15s ease, background .15s ease;
    }

        .bb-ico:hover {
            background: rgba(255,255,255,.28);
            transform: translateY(-1px);
        }

        .bb-ico span {
            font-size: 14px;
        }

    /* ===== Wrapper ===== */
    .bb-wrap {
        width: 100vw;
        min-height: 100vh;
        max-width: none !important;
        margin: 0 !important;
        padding: 10px;
        box-sizing: border-box;
    }

    @@supports (height: 100dvh) {
        .bb-wrap {
            min-height: 100dvh;
        }
    }

    /* =========================================================
                ✅ PAIR ROW LAYOUT: TPS=DPS, RPS1=RPS2, FWS1=FWS2, CHEM1=CHEM2
            ========================================================= */
    .bb-pairs {
        display: grid;
        grid-template-columns: 1fr; /* rows */
        gap: 10px;
    }

    .bb-row {
        display: grid;
        grid-template-columns: 1fr 1fr; /* left/right */
        gap: 10px;
        align-items: stretch;
    }

        /* ✅ สำคัญ: คู่ในแถวเดียวกันต้องสูงเท่ากัน */
        .bb-row > .bb-section {
            height: 100%;
        }

    @@media (max-width: 1100px) {
        .bb-row {
            grid-template-columns: 1fr;
        }
    }

    /* ===== Section panel ===== */
    .bb-section {
        background: var(--panel);
        border: 1px solid var(--stroke);
        border-radius: 10px;
        overflow: hidden;
        /* ✅ ทำให้ body ของ section ยืดตามความสูงแถว */
        display: flex;
        flex-direction: column;
        min-height: 0;
        padding: 8px;
    }

    .bb-section-h {
        display: flex;
        align-items: center;
        padding: 6px 10px;
        background: rgba(0,0,0,.18);
        border-bottom: 1px solid var(--stroke);
        font-weight: 800;
    }

    /* ===== เพิ่ม gap 5px รอบ -h และ -b ===== */
    .bb-section > .bb-section-h,
    .bb-section > .bb-section-b {
        margin: 5px; /* ← gap รอบด้าน */
    }

    /* กัน header ติดเส้น border-bottom ซ้อน */
    .bb-section > .bb-section-h {
        margin-bottom: 5px;
    }

    /* ซ้าย */
    .bb-section-h .left {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    /* ขวา (ไอคอน) */
    .bb-section-h .right-icons {
        margin-left: auto; /* ดันไปขวาสุด */
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* ไอคอนให้เป็นปุ่มแบบ dashboard */
    .bb-ico {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(0,0,0,.20);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        padding: 0;
        color: inherit;
    }

        .bb-ico:hover {
            background: rgba(255,255,255,.18);
        }

        .bb-ico:active {
            transform: translateY(1px);
        }

        .bb-ico span {
            line-height: 1;
        }

        .bb-ico.is-muted {
            background: rgba(255,255,255,.08);
            opacity: .7;
        }

        .bb-ico.is-armed {
            background: rgba(255,204,77,.16);
            border-color: rgba(255,204,77,.28);
        }

        .bb-ico.is-alerting {
            background: rgba(255,91,91,.2);
            border-color: rgba(255,91,91,.35);
            box-shadow: 0 0 0 1px rgba(255,91,91,.2), 0 0 12px rgba(255,91,91,.25);
        }

    .zone {
        display: grid;
        grid-template-columns: 96px 1fr; /* ✅ ขยายคอลัมน์ pump */
        gap: 14px; /* ✅ เพิ่มช่องไฟระหว่าง pump กับ KPI */
        align-items: start;
    }

    /* กันชิดอีกชั้น */
    .pump-col {
        display: flex;
        flex-direction: column;
        gap: 8px; /* 👈 เพิ่มระยะห่างระหว่าง Pump1-4 */
        padding-right: 3px;
    }


    .pump {
        height: 36px;
        border-radius: 6px;
        border: 1px solid rgba(0,0,0,.25);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 8px;
        background: rgba(255,255,255,.06);
    }

        .pump .tag {
            font-size: 11px;
            opacity: .85;
        }

        .pump .st {
            font-size: 11px;
            font-weight: 800;
            padding: 2px 6px;
            border-radius: 999px;
            border: 1px solid rgba(0,0,0,.25);
        }

    .st.on {
        background: rgba(90,211,109,.18);
        color: #bfffd0;
    }

    .st.off {
        background: rgba(255,91,91,.18);
        color: #ffd0d0;
    }

    .st.rep {
        background: rgba(255,204,77,.18);
        color: #fff2c8;
    }

    /* ===== KPI row ===== */
    .kpi-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: 10px;
        align-items: stretch;
    }

    /* ✅ ทุกการ์ดใน grid ให้ยืดเท่ากัน */
    .kpi, .mini-card {
        height: 100%;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
        min-width: 150px;
    }

    .kpi {
        background: var(--card);
        border: 1px solid var(--stroke);
        border-radius: 10px;
        padding: 10px;
        min-height: 175px;
    }

        .kpi .lab {
            font-size: 11px;
            opacity: .75;
            letter-spacing: .2px;
        }

        .kpi .val {
            font-size: 34px;
            font-weight: 900;
            color: #5fe4ff;
            line-height: 1.05;
        }

        .kpi.small .val {
            font-size: 26px;
        }

        .kpi .sub {
            margin-top: auto; /* ✅ ดันท้ายการ์ดให้สมมาตร */
            font-size: 14px;
            color: var(--muted);
            display: flex;
            justify-content: space-between;
            gap: 10px;
        }
    /* Big centered value */
    .val-center {
        display: flex;
        align-items: center; /* กึ่งกลางแนวตั้ง */
        justify-content: center; /* กึ่งกลางแนวนอน */
        text-align: center;
        font-size: 42px; /* ใหญ่กว่าเดิม */
        font-weight: 900;
        color: #5fe4ff;
        line-height: 1.1;
        flex: 1; /* กินพื้นที่ใน card */
    }

        /* เวอร์ชันเล็ก */
        .val-center.small {
            font-size: 30px;
        }

    .mini-card {
        background: var(--card2);
        border: 1px solid var(--stroke);
        border-radius: 10px;
        padding: 10px;
        min-height: 140px;
    }

        .mini-card .lab {
            font-size: 11px;
            opacity: .75;
        }

        .mini-card .val {
            margin-top: 3px;
            font-size: 18px;
            font-weight: 900;
        }

        .mini-card .mut {
            font-size: 11px;
            color: var(--muted);
            margin-top: 3px;
        }

    /* chart placeholder */
    .chart {
        flex: 1;
        min-height: 76px;
        border-radius: 10px;
        border: 1px dashed rgba(255,255,255,.18);
        background: rgba(255,255,255,.04);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,.55);
        font-size: 12px;
        margin-top: 8px;
    }

    /* ✅ override chart placeholder เดิม ให้ canvas แสดงจริง */
    .mini-card .chart {
        position: relative;
        height: 140px;
        min-height: 140px;
        display: block; /* ✅ ทับ display:flex เดิม */
    }

        .mini-card .chart canvas.bb-trend-chart {
            width: 100% !important;
            height: 100% !important;
            display: block !important;
        }


        .mini-card .chart canvas.bb-trend-chart {
            width: 100% !important;
            height: 100% !important;
            display: block !important;
        }

    /* ===== reusable row grids ===== */
    .row4 {
        margin-top: 10px;
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: 10px;
        align-items: stretch;
    }

        .row4 > .mini-card {
            min-height: 195px;
        }

    .row4charts {
        margin-top: 10px;
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: 10px;
        align-items: stretch;
    }

        .row4charts > .mini-card {
            min-height: 120px;
        }

    /* ===== Matrix / FWS ===== */
    .matrix {
        display: grid;
        grid-template-columns: 220px 1fr 1fr;
        gap: 10px;
        align-items: start;
    }

        .matrix .leftbox {
            background: rgba(0,0,0,.12);
            border: 1px solid var(--stroke);
            border-radius: 10px;
            padding: 10px;
        }

    .leftbox .row {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        color: var(--muted);
        padding: 4px 0;
        border-bottom: 1px solid rgba(255,255,255,.06);
    }

        .leftbox .row:last-child {
            border-bottom: none;
        }

    .tagpill {
        padding: 2px 8px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 11px;
        border: 1px solid rgba(0,0,0,.25);
    }

        .tagpill.a {
            background: rgba(90,211,109,.18);
            color: #c9ffd6;
        }

        .tagpill.b {
            background: rgba(255,91,91,.18);
            color: #ffd0d0;
        }

        .tagpill.c {
            background: rgba(255,204,77,.18);
            color: #fff0c2;
        }

    .units {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 6px;
        margin-bottom: 10px;
    }

    .u {
        height: 26px;
        border-radius: 7px;
        border: 1px solid rgba(0,0,0,.25);
        background: rgba(255,255,255,.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 12px;
    }

        .u.ok {
            background: rgba(90,211,109,.22);
        }

        .u.bad {
            background: rgba(255,91,91,.22);
        }

        .u.warn {
            background: rgba(255,204,77,.18);
        }

    /* ===== CHEM ===== */
    .chem-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1.2fr;
        gap: 10px;
        align-items: stretch;
    }

    .chem-box {
        background: var(--card);
        border: 1px solid var(--stroke);
        border-radius: 10px;
        padding: 10px;
        display: flex;
        flex-direction: column;
        min-height: 160px;
    }

        .chem-box .h {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

            .chem-box .h .t {
                font-weight: 900;
            }

        .chem-box .tank {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

    .tank .cell {
        border: 1px solid rgba(255,255,255,.10);
        border-radius: 10px;
        background: rgba(255,255,255,.05);
        padding: 8px;
    }

    .cell .lab {
        font-size: 11px;
        opacity: .75;
    }

    .cell .val {
        font-size: 18px;
        font-weight: 900;
        margin-top: 2px;
    }

    .sidepanel {
        background: rgba(0,0,0,.18);
        border: 1px solid var(--stroke);
        border-radius: 10px;
        padding: 10px;
        min-height: 160px;
        display: flex;
        flex-direction: column;
    }

        .sidepanel .h {
            font-weight: 900;
            margin-bottom: 8px;
        }

        .sidepanel .line {
            font-size: 12px;
            color: var(--muted);
            padding: 4px 0;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

            .sidepanel .line:last-child {
                border-bottom: none;
            }

    .smallbtn {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 28px;
        padding: 0 10px;
        border-radius: 8px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(0,0,0,.25);
        color: rgba(255,255,255,.9);
        font-weight: 800;
        font-size: 12px;
        width: fit-content;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        display: inline-block;
        margin-right: 6px;
        border: 1px solid rgba(0,0,0,.35);
    }

        .dot.g {
            background: var(--green);
        }

        .dot.r {
            background: var(--red);
        }

        .dot.y {
            background: var(--amber);
        }

    .lab-split {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        width: 100%;
    }

        .lab-split span:last-child {
            opacity: .75; /* optional */
            font-weight: 700; /* optional */
        }

    /* ===== Overview card ===== */
    .ov-card {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .ov-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .ov-title {
        font-size: 12px;
        font-weight: 900;
        opacity: .85;
        letter-spacing: .2px;
    }

    .val-center {
        margin-bottom: 20px; /* ปรับ 8–14px ตามความสวย */
    }

    .ov-status {
        font-size: 11px;
        font-weight: 900;
        padding: 3px 10px;
        border-radius: 999px;
        border: 1px solid rgba(0,0,0,.25);
        background: rgba(255,255,255,.08);
        opacity: .95;
    }

        /* สีสถานะ */
        .ov-status.ok {
            background: rgba(90,211,109,.18);
            color: #c9ffd6;
        }

        .ov-status.warn {
            background: rgba(255,204,77,.18);
            color: #fff2c8;
        }

        .ov-status.bad {
            background: rgba(255,91,91,.18);
            color: #ffd0d0;
        }

    .ov-sub {
        font-size: 11px;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .ov-value {
        flex: 1; /* ✅ ดันให้เลขอยู่กลางการ์ด */
        display: flex;
        align-items: flex-start;
        justify-content: center;
        text-align: center;
        font-size: 20px;
        font-weight: 900;
        color: #eaf6ff; /* ให้ขาวนวล อ่านง่าย */
        letter-spacing: .3px;
        line-height: 1.05;
    }

    .ov-unit {
        font-size: 12px;
        opacity: .75;
        margin-left: 6px;
        font-weight: 800;
    }

    .ov-foot {
        text-align: center;
        font-size: 11px;
        color: var(--muted);
        letter-spacing: .3px;
        padding-bottom: 2px;
    }

    /* ============================
                               Tank KPI (use your HTML)
                               .mini-card.tank-kpi ok|warn|bad
                               ============================ */

    /* card layout: ซ้าย KPI / ขวา tank */
    .row4 .mini-card.tank-kpi {
        display: grid;
        grid-template-columns: 1fr 40px; /* ✅ tank แคบลงเหมือนตัวอย่าง */
        grid-template-rows: auto 1fr; /* hdr แล้วค่อย body */
        column-gap: 10px;
        row-gap: 6px;
        align-items: stretch;
        min-height: 128px; /* ✅ แน่นขึ้น */
        padding: 5px; /* ✅ ลดช่องว่าง */
    }

    /* header เต็มการ์ด */
    .tank-kpi .hdr {
        grid-column: 1 / 3;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 10px;
        margin: 0;
    }

        .tank-kpi .hdr .name {
            font-size: 12px;
            font-weight: 900;
            opacity: .92;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .tank-kpi .hdr .max {
            font-size: 11px;
            opacity: .70;
            white-space: nowrap;
        }

    /* KPI ฝั่งซ้าย: ΔQ/Pin/Pout แน่นๆ */
    .tank-kpi .kpis {
        grid-column: 1 / 2;
        display: grid;
        gap: 1px;
        align-content: start;
        margin-top: 2px;
    }

        /* ให้ status อยู่บรรทัดแรกของ KPI */
        .tank-kpi .kpis .ov-status {
            justify-self: start; /* ✅ ชิดซ้ายใน grid */
            align-self: start;
            height: 20px;
            padding: 0 10px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            margin-bottom: 2px; /* ✅ เว้นนิดเดียวก่อน ΔQ */
        }

    /* ลด gap ของ kpis ให้แน่นเหมือนตัวอย่าง */
    .tank-kpi .kpis {
        gap: 2px; /* เดิม 1px ก็ได้ แต่ status จะดูติดเกิน */
    }


    /* 1 แถว = label | value | unit */
    .tank-kpi .kv {
        display: grid;
        grid-template-columns: 34px 1fr auto;
        gap: 8px;
        align-items: baseline;
        line-height: 1.1;
        margin-top: 15px;
    }

        .tank-kpi .kv .k {
            font-size: 11px;
            opacity: .70;
        }

        .tank-kpi .kv .v {
            font-size: 18px;
            font-weight: 900;
            letter-spacing: .2px;
            text-align: right;
        }

        .tank-kpi .kv .u {
            font-size: 11px;
            opacity: .65;
            white-space: nowrap;
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            padding: 0 !important;
        }

        /* ΔQ ให้เด่นกว่านิด */
        .tank-kpi .kv:first-child .v {
            font-size: 20px;
        }

    /* =========================
                               Gauge (แท่งด้านขวา)
                               ========================= */
    .tank-kpi .gauge {
        grid-column: 2 / 3;
        grid-row: 2 / 3;
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 0; /* ✅ ไม่มีกรอบครอบ */
        background: transparent;
        border: none;
        border-radius: 0;
        min-width: 0;
    }

    /* Tank / 66% */
    .tank-kpi .g-top {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 2px;
    }

        .tank-kpi .g-top .t {
            font-size: 11px;
            font-weight: 900;
            opacity: .75;
        }

        .tank-kpi .g-top .p {
            margin-left: auto; /* ✅ เผื่อกรณีมี element อื่น */
            text-align: right;
            font-size: 11px;
            font-weight: 900;
            opacity: .80;
        }

    /* แท่ง */
    .tank-kpi .well {
        position: relative;
        flex: 1;
        border-radius: 12px;
        background: rgba(0,0,0,.22);
        overflow: hidden;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
    }

    /* เติมจากล่างขึ้นบน (ใช้ --fill 0..100 บน .gauge) */
    .tank-kpi .fill {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: calc(var(--fill, 0) * 1%);
        box-shadow: 0 -10px 18px rgba(0,0,0,.10);
    }

    /* ตัวเลขกลางแท่ง */
    .tank-kpi .read {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-weight: 900;
        color: rgba(255,255,255,.95);
        text-shadow: 0 1px 0 rgba(0,0,0,.35);
    }

        .tank-kpi .read .val {
            font-size: 16px;
            line-height: 1.1;
        }

    /* =========================
                               สีตามสถานะ: ok / warn / bad
                               (อิงคลาสที่ mini-card)
                               ========================= */
    .tank-kpi.ok .fill {
        background: linear-gradient(180deg, rgba(95,228,255,.85), rgba(90,211,109,.78));
    }

    .tank-kpi.warn .fill {
        background: linear-gradient(180deg, rgba(255,204,77,.92), rgba(255,153,51,.78));
    }

    .tank-kpi.bad .fill {
        background: linear-gradient(180deg, rgba(255,91,91,.92), rgba(255,91,91,.55));
    }

    /* (เสริม) อยากให้สีตัวเลขในแท่งเปลี่ยนตามสถานะด้วย */
    .tank-kpi.ok .read .val {
        color: rgba(234,246,255,.98);
    }

    .tank-kpi.warn .read .val {
        color: rgba(255,248,220,.98);
    }

    .tank-kpi.bad .read .val {
        color: rgba(255,235,235,.98);
    }

    /* header ของ mini-card แบบมี dropdown ขวา */
    .mini-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

        .mini-head .lab {
            margin: 0; /* กันระยะเดิมของ lab */
            flex: 1;
            min-width: 0;
        }

    /* dropdown style ให้เข้าธีม */
    .bb-dd {
        height: 26px;
        padding: 0 10px;
        border-radius: 10px;
        border: 1px solid var(--stroke);
        background: rgba(0,0,0,.22);
        color: rgba(255,255,255,.90);
        font-size: 12px;
        font-weight: 800;
        outline: none;
        cursor: pointer;
    }

        /* เงา/ขอบตอนโฟกัส */
        .bb-dd:focus {
            box-shadow: 0 0 0 2px rgba(51,209,255,.18);
        }

        /* option ใน dropdown (บาง browser จะไม่สน style มาก) */
        .bb-dd option {
            background: #22282c;
            color: rgba(255,255,255,.92);
        }

    /* ===== RPS one block grid (ตามรูป) ===== */
    .rps-grid {
        display: grid;
        grid-template-columns: 96px minmax(0,1fr) minmax(0,1fr) minmax(0,1fr) minmax(0,1fr);
        grid-auto-rows: minmax(175px, auto); /* ให้ 2 แถวสูงเท่ากันแนวเดียวกับรูป */
        gap: 20px;
        align-items: stretch;
    }

        /* วางตำแหน่งตามแถว/คอลัมน์ */
        .rps-grid .r1 {
            grid-column: 1;
            grid-row: 1;
        }

        .rps-grid .r2 {
            grid-column: 1;
            grid-row: 2;
        }

        .rps-grid .r1c2 {
            grid-column: 2;
            grid-row: 1;
        }

        .rps-grid .r1c3 {
            grid-column: 3;
            grid-row: 1;
        }

        .rps-grid .r1c4 {
            grid-column: 4;
            grid-row: 1;
        }

        .rps-grid .r1c5 {
            grid-column: 5;
            grid-row: 1;
        }

        .rps-grid .r2c2 {
            grid-column: 2;
            grid-row: 2;
        }

        .rps-grid .r2c3 {
            grid-column: 3;
            grid-row: 2;
        }

        .rps-grid .r2c4 {
            grid-column: 4;
            grid-row: 2;
        }

        .rps-grid .r2c5 {
            grid-column: 5;
            grid-row: 2;
        }

        /* ให้การ์ดทุกใบ “เต็มช่อง” */
        .rps-grid .kpi,
        .rps-grid .mini-card {
            height: 100%;
            min-height: 175px; /* ถ้าต้องการสูงเท่ากันเป๊ะ */
        }

        /* (ถ้าอยากให้ pump กล่องสูงเท่ากับแถวด้วย) */
        .rps-grid .pump-col {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .rps-grid .pump {
            height: 32px;
        }
    /* ใกล้รูปตัวอย่าง */

    /* Responsive: จอแคบให้เรียงลง (ตัด chart ไปแถวถัดไป) */
    @@media (max-width: 1100px) {
        .rps-grid {
            grid-template-columns: 96px minmax(0,1fr) minmax(0,1fr);
            grid-auto-rows: auto;
        }

            .rps-grid .r1c4 {
                grid-column: 2;
                grid-row: 3;
            }

            .rps-grid .r1c5 {
                grid-column: 3;
                grid-row: 3;
            }

            .rps-grid .r2c4 {
                grid-column: 2;
                grid-row: 4;
            }

            .rps-grid .r2c5 {
                grid-column: 3;
                grid-row: 4;
            }
    }

    /* CHEM block: ให้ top spacing เท่ากับ RPS */
    .chem-block .row4 {
        margin-top: 0; /* เดิม row4 = 10px */
    }

    /* (ถ้าต้องการให้ padding/แนวเริ่มเท่ากันชัวร์) */
    .chem-block .bb-section-b {
        padding: 0px; /* คงไว้เท่ากับ section อื่น */
    }

    /* =========================
                               CHEM block (Alum Consumption cards)
                               ========================= */

    .chem-grid2 {
        display: grid;
        grid-template-columns: 1fr 1fr 1.3fr; /* 👈 1:1:1.5 */
        gap: 10px;
        align-items: stretch;
    }


    /* responsive */
    @@media (max-width: 1100px) {
        .chem-grid2 {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .chem-grid2 {
            grid-template-columns: 1fr;
        }
    }

    /* =========================================================
               CHEM CARD (Unified) 70:30 + Equipment Slots
               ========================================================= */

    /* card base */
    .chem-card {
        --accent: var(--green);
        --accentSoft: rgba(90,211,109,.18);
        --ink: rgba(255,255,255,.92);
        background: rgba(0,0,0,.10);
        border: 1px solid var(--stroke);
        border-radius: 12px;
        padding: 8px;
        box-sizing: border-box;
        overflow: hidden;
        /* ✅ 70:30 */
        display: grid;
        grid-template-columns: minmax(0,75fr) minmax(120px,25fr);
        grid-template-rows: auto 1fr;
        gap: 8px;
        min-height: 180px;
    }

        /* theme variants */
        .chem-card.ok {
            --accent: var(--green);
            --accentSoft: rgba(90,211,109,.18);
        }

        .chem-card.warn {
            --accent: var(--amber);
            --accentSoft: rgba(255,204,77,.18);
        }

        .chem-card.bad {
            --accent: var(--red);
            --accentSoft: rgba(255,91,91,.18);
        }

        /* header */
        .chem-card .hdr {
            grid-column: 1 / -1;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding-bottom: 0px;
        }

    .chem-title {
        font-weight: 900;
        letter-spacing: .2px;
        font-size: 13px;
        opacity: .95;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chem-right {
        display: flex;
        align-items: center;
        gap: 15px;
        justify-content: flex-end;
        min-width: 0;
        margin-right: 10px;
    }

    /* status pill */
    .chem-pill {
        height: 18px;
        padding: 0 10px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        font-size: 11px;
        font-weight: 900;
        /* ชัดขึ้น */
        background: color-mix(in srgb, var(--accent) 78%, #000 22%);
        border: 1px solid color-mix(in srgb, var(--accent) 65%, #fff 35%);
        color: rgba(255,255,255,.95);
        text-shadow: 0 1px 0 rgba(0,0,0,.45);
        box-shadow: 0 0 0 1px rgba(0,0,0,.18), 0 0 10px color-mix(in srgb, var(--accent) 55%, transparent);
    }

    /* ===== status chips (ON / STBY / REP / OFF) ===== */
    .chem-chip {
        height: 18px;
        padding: 0 8px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 900;
        line-height: 18px;
        border: 1px solid rgba(255,255,255,.14);
        background: rgba(255,255,255,.08);
        color: rgba(255,255,255,.85);
        opacity: .95;
    }

        /* ON = เขียว */
        .chem-chip.on {
            background: #39d98a;
            border-color: #39d98a;
            color: rgba(0,0,0,.88);
        }

        /* STBY = แดง */
        .chem-chip.stby {
            background: #ff4d4f;
            border-color: #ff4d4f;
            color: rgba(255,255,255,.92);
        }

        /* REP = ดำ/เทาเข้ม */
        .chem-chip.rep {
            background: rgba(0,0,0,.55);
            border-color: rgba(255,255,255,.12);
            color: rgba(255,255,255,.88);
        }

        /* OFF (ถ้าใช้) */
        .chem-chip.off {
            background: rgba(255,255,255,.10);
            border-color: rgba(255,255,255,.10);
            color: rgba(255,255,255,.70);
        }

    /* left column */
    .chem-body {
        grid-column: 1;
        grid-row: 2;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    /* lines base */
    .chem-lines {
        display: grid;
        gap: 0px;
        font-size: 15px;
        color: rgba(255,255,255,.86);
    }

    .chem-line {
        display: flex;
        gap: 12px;
        align-items: baseline;
    }

        .chem-line .k {
            width: 65px;
            font-weight: 900;
            opacity: .92;
            white-space: nowrap;
        }

        .chem-line .v {
            font-weight: 800;
            opacity: .92;
            white-space: nowrap;
        }

    /* =========================
               Chlorine lines: compact columns
               ========================= */
    .chem-lines.chem-lines--cl {
        gap: 2px;
    }

        .chem-lines.chem-lines--cl .chem-line {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            column-gap: 8px;
            align-items: center;
            line-height: 1.0;
            padding: 1px 0;
            border-bottom: 1px solid rgba(255,255,255,.06);
            margin-bottom: 2px;
        }

            .chem-lines.chem-lines--cl .chem-line:last-child {
                border-bottom: none;
            }

            .chem-lines.chem-lines--cl .chem-line .k {
                width: auto;
                font-weight: 900;
                opacity: .90;
                letter-spacing: .2px;
                text-align: left;
                white-space: nowrap;
            }

            .chem-lines.chem-lines--cl .chem-line .v {
                display: inline-flex;
                gap: 0px;
                justify-content: flex-start;
                align-items: baseline;
                font-weight: 900;
                opacity: .92;
                font-variant-numeric: tabular-nums;
                min-width: 0;
                display: contents;
            }

                .chem-lines.chem-lines--cl .chem-line .v .mg {
                    width: auto;
                    text-align: right;
                    opacity: .95;
                    white-space: nowrap;
                    font-variant-numeric: tabular-nums;
                }

                .chem-lines.chem-lines--cl .chem-line .v .lh {
                    width: auto;
                    text-align: right;
                    opacity: .85;
                    white-space: nowrap;
                    font-variant-numeric: tabular-nums;
                }

    /* =========================
               Equipment Slot Bar (UNIFIED)
               ========================= */
    .chem-eqbar {
        margin-top: 2px;
        padding-top: 8px;
        border-top: 1px solid rgba(255,255,255,.08);
        display: grid;
        gap: 8px;
    }

    .eq-line {
        display: grid;
        grid-template-columns: 86px 1fr; /* ✅ label กินที่พอ ไม่ต้องดัน content */
        gap: 10px;
        align-items: center;
    }

    .eq-label {
        font-size: 11px;
        font-weight: 900;
        opacity: .72;
        letter-spacing: .5px;
        white-space: nowrap;
    }

    /* slot container */
    .eq-slots {
        display: grid;
        gap: 6px;
        justify-content: start;
    }

    .eq-3 {
        grid-template-columns: repeat(3,16px);
    }

    .eq-4 {
        grid-template-columns: repeat(4,16px);
    }

    .eq-5 {
        grid-template-columns: repeat(5,16px);
    }

    /* slot */
    .eq-slot {
        width: 16px;
        height: 14px;
        border-radius: 2px;
        border: 1px solid rgba(255,255,255,.15);
        background: rgba(0,0,0,.22);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.04);
        position: relative;
    }

        /* states */
        .eq-slot.on {
            background: color-mix(in srgb, var(--accent) 70%, #39d98a);
            border-color: color-mix(in srgb, var(--accent) 70%, #39d98a);
            box-shadow: 0 0 6px rgba(57,217,138,.45);
        }

        .eq-slot.stby {
            background: #ff4d4f; /* ตามที่คุณใช้: stby = แดง */
            border-color: #ff4d4f;
        }

        /* REP = เทาเดิม */
        .eq-slot.rep {
            background: rgba(255,255,255,.10);
            border-color: rgba(255,255,255,.10);
        }

            /* กากบาทแดง (X) สำหรับ REP */
            .eq-slot.rep::before,
            .eq-slot.rep::after {
                content: "";
                position: absolute;
                left: 50%;
                top: 50%;
                width: 18px; /* ความยาวเส้น X */
                height: 2px; /* ความหนาเส้น */
                background: #ff4d4f; /* แดง */
                border-radius: 2px;
                transform-origin: center;
                opacity: .95;
                box-shadow: 0 0 4px rgba(255,77,79,.35);
            }

            .eq-slot.rep::before {
                transform: translate(-50%,-50%) rotate(45deg);
            }

            .eq-slot.rep::after {
                transform: translate(-50%,-50%) rotate(-45deg);
            }

        .eq-slot.fault {
            background: #ff9f1a;
            border-color: #ff9f1a;
        }

    /* right column (gauges) */
    .chem-gauges {
        grid-column: 2;
        grid-row: 2;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        align-items: stretch;
        min-width: 0;
        margin-right: 10px;
        margin-left: 10px;
    }

    /* tank */
    .chem-tank {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 0;
    }

    .chem-well {
        position: relative;
        height: 116px;
        border-radius: 12px;
        background: rgba(0,0,0,.28);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
        overflow: hidden;
    }

    .chem-fill {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: calc(var(--fill,0) * 1%);
        background: linear-gradient( 180deg, rgba(95,228,255,.70), color-mix(in srgb, var(--accent) 70%, transparent) );
        opacity: .95;
    }

    .chem-read {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        color: rgba(0,0,0,.75);
        text-shadow: 0 1px 0 rgba(255,255,255,.25);
        font-size: 13px;
    }

    .chem-cap {
        font-size: 9px;
        line-height: 1.1;
        text-align: center;
        opacity: .85;
        color: rgba(255,255,255,.70);
    }

        .chem-cap b {
            color: rgba(255,255,255,.88);
        }

    /* กันการ์ดดันคอลัมน์แตก (ของเดิมคุณ) */
    .bb-slots {
        display: grid;
        grid-template-columns: repeat(2, minmax(0,1fr));
        gap: 10px;
        align-items: stretch;
    }

    .bb-slot {
        min-width: 0;
    }

        .bb-slot > .bb-section {
            min-width: 0;
        }

    @@media (max-width: 1100px) {
        .bb-slots {
            grid-template-columns: 1fr;
        }
    }

    /* ===== Settings Modal ===== */
    .bb-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.55);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 18px;
        z-index: 2147483647;
        pointer-events: auto;
        isolation: isolate;
    }

        .bb-modal-backdrop.is-open {
            display: flex;
        }

    html.bb-modal-open,
    body.bb-modal-open {
        overflow: hidden;
    }

    .bb-modal {
        position: relative;
        z-index: 1;
        width: min(900px, 96vw);
        max-height: calc(100dvh - 36px);
        background: #22282c;
        border: 1px solid var(--stroke);
        border-radius: 14px;
        box-shadow: 0 18px 60px rgba(0,0,0,.55);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        pointer-events: auto;
    }

    .bb-modal-h {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 12px;
        background: rgba(255,255,255,.06);
        border-bottom: 1px solid var(--stroke);
    }

        .bb-modal-h .t {
            font-weight: 900;
            letter-spacing: .2px;
        }

        .bb-modal-h .x {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            border: 1px solid var(--stroke);
            background: rgba(0,0,0,.22);
            color: rgba(255,255,255,.88);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
        }

    .bb-modal-b {
        padding: 12px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        overflow: auto;
        min-height: 0;
    }

    @@media (max-width: 860px) {
        .bb-modal-b {
            grid-template-columns: 1fr;
        }
    }

    .slot-card {
        background: rgba(0,0,0,.14);
        border: 1px solid var(--stroke);
        border-radius: 12px;
        padding: 10px;
    }

        .slot-card .hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }

            .slot-card .hdr .name {
                font-weight: 900;
                opacity: .92;
            }

        .slot-card .hint {
            font-size: 11px;
            color: var(--muted);
            margin-top: 6px;
        }

    .bb-modal-f {
        position: sticky;
        bottom: 0;
        z-index: 2;
        padding: 10px 12px;
        border-top: 1px solid var(--stroke);
        background: #22282c;
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        pointer-events: auto;
    }

    .bb-btn {
        height: 32px;
        padding: 0 12px;
        border-radius: 10px;
        border: 1px solid var(--stroke);
        background: rgba(0,0,0,.22);
        color: rgba(255,255,255,.92);
        font-weight: 900;
        font-size: 12px;
        cursor: pointer;
    }

        .bb-btn.primary {
            position: relative;
            z-index: 3;
            background: rgba(51,209,255,.16);
            border-color: rgba(51,209,255,.22);
            pointer-events: auto;
        }

        .bb-btn.danger {
            background: rgba(255,91,91,.12);
            border-color: rgba(255,91,91,.22);
        }


    /* ===== User Feedback Modal ===== */
    .bb-ico {
        cursor: pointer;
        user-select: none;
    }

    .bb-feedback-modal {
        width: min(560px, 96vw);
    }

    .bb-feedback-b {
        display: block;
        padding: 14px;
        overflow: auto;
        min-height: 0;
    }

    .bb-feedback-intro {
        margin: 0 0 12px;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.45;
    }

    .bb-feedback-field {
        margin-bottom: 12px;
    }

    .bb-feedback-label {
        display: flex;
        align-items: baseline;
        justify-content: space-between;

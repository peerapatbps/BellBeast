<section class="bb-section cldetector-block">
    <style>
        section.cldetector-block {
            min-height: 100%;
        }

            section.cldetector-block .bb-section-b {
                flex: 1;
                min-height: 0;
            }

            section.cldetector-block .cld-wrap {
                height: 100%;
                min-height: 420px;
                max-height: 420px;
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 14px;
            }

            section.cldetector-block .cld-panel {
                min-width: 0;
                min-height: 0;
                display: flex;
                flex-direction: column;
                overflow: hidden;
                border-radius: 22px;
                border: 1px solid rgba(255,255,255,.10);
                background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.02)), linear-gradient(135deg, rgba(21,28,40,.96), rgba(7,11,20,.98));
                box-shadow: inset 0 1px 0 rgba(255,255,255,.06), 0 18px 40px rgba(0,0,0,.28);
                backdrop-filter: blur(16px) saturate(135%);
            }

            section.cldetector-block .cld-head {
                padding: 12px 16px;
                border-bottom: 1px solid rgba(255,255,255,.08);
                font-size: 14px;
                font-weight: 900;
                color: #eef4ff;
                background: linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.01));
            }

            section.cldetector-block .cld-body {
                flex: 1;
                min-height: 0;
                padding: 14px;
                display: flex;
                flex-direction: column;
                overflow: hidden;
            }

            section.cldetector-block .cld-map {
                position: relative;
                flex: 1;
                min-height: 0;
                height: 100%;
                border-radius: 24px;
                border: 1px solid rgba(255,255,255,.08);
                overflow: hidden;
                background: radial-gradient(circle at 14% 18%, rgba(34,197,94,.08), transparent 26%), radial-gradient(circle at 78% 74%, rgba(244,63,94,.10), transparent 26%), linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01)), linear-gradient(180deg, #0d1523, #09111d);
                box-shadow: inset 0 1px 0 rgba(255,255,255,.05), inset 0 -20px 40px rgba(255,255,255,.02), 0 12px 24px rgba(0,0,0,.20);
            }

                section.cldetector-block .cld-map::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: repeating-linear-gradient(0deg, rgba(148,163,184,.05) 0, rgba(148,163,184,.05) 1px, transparent 1px, transparent 32px), repeating-linear-gradient(90deg, rgba(148,163,184,.05) 0, rgba(148,163,184,.05) 1px, transparent 1px, transparent 32px);
                    opacity: .45;
                    pointer-events: none;
                }

            section.cldetector-block .room {
                position: absolute;
                border-radius: 24px;
                border: 1px solid rgba(255,255,255,.18);
                background: linear-gradient(180deg, rgba(255,255,255,.24), rgba(255,255,255,.08)), linear-gradient(135deg, rgba(184,220,255,.18), rgba(191,255,231,.10));
                box-shadow: inset 0 1px 0 rgba(255,255,255,.22), 0 10px 24px rgba(0,0,0,.18);
                backdrop-filter: blur(18px) saturate(140%);
            }

                section.cldetector-block .room.storage {
                    left: 6%;
                    top: 24%;
                    width: 63%;
                    height: 50%;
                }

                section.cldetector-block .room.dosing {
                    left: 73%;
                    top: 24%;
                    width: 20%;
                    height: 50%;
                    padding-top: 22px;
                    box-sizing: border-box;
                }

            section.cldetector-block .room-title {
                position: absolute;
                left: 50%;
                transform: translateX(-50%);
                color: rgba(245,249,255,.97);
                text-transform: uppercase;
                font-weight: 900;
                letter-spacing: .03em;
                text-align: center;
                line-height: 1.02;
                text-shadow: 0 1px 0 rgba(0,0,0,.24);
                pointer-events: none;
                z-index: 3;
            }

            section.cldetector-block .room.storage .room-title {
                top: 42%;
                font-size: 18px;
            }

            section.cldetector-block .room.dosing .room-title {
                top: 9px;
                width: calc(100% - 10px);
                font-size: 14px;
            }

            section.cldetector-block .door {
                position: absolute;
                background: linear-gradient(180deg, #ff3b30, #e11d1d);
                box-shadow: 0 0 0 1px rgba(255,90,90,.22), 0 0 18px rgba(255,59,48,.16);
                z-index: 2;
            }

            section.cldetector-block .storage-door-left {
                left: -8px;
                top: 30%;
                width: 8px;
                height: 58px;
                border-radius: 8px 0 0 8px;
            }

            section.cldetector-block .storage-door-top {
                left: 78%;
                transform: translateX(-50%);
                top: -8px;
                width: 52px;
                height: 8px;
                border-radius: 8px 8px 0 0;
            }

            section.cldetector-block .dosing-door-top {
                left: 50%;
                transform: translateX(-50%);
                top: -8px;
                width: 38px;
                height: 8px;
                border-radius: 8px 8px 0 0;
            }

            section.cldetector-block .det {
                position: absolute;
                display: flex;
                align-items: center;
                gap: 8px;
                z-index: 4;
            }

            section.cldetector-block .pill {
                min-width: 38px;
                height: 28px;
                padding: 0 10px;
                border-radius: 999px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: linear-gradient(180deg, rgba(28,36,52,.96), rgba(14,20,33,.98));
                border: 1px solid rgba(255,255,255,.08);
                color: #f4f8ff;
                font-size: 12px;
                font-weight: 900;
                line-height: 1;
                box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 8px 18px rgba(0,0,0,.22);
                white-space: nowrap;
            }

            section.cldetector-block .dot {
                width: 34px;
                height: 34px;
                border-radius: 999px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                color: #fff;
                font-size: 14px;
                font-weight: 900;
                line-height: 1;
                border: 2px solid rgba(255,255,255,.9);
                box-shadow: 0 0 0 4px rgba(255,255,255,.08), 0 10px 18px rgba(0,0,0,.20);
                flex: 0 0 auto;
            }

            section.cldetector-block .normal {
                background: linear-gradient(180deg, #34d399, #10b981);
            }

            section.cldetector-block .alarm1 {
                background: linear-gradient(180deg, #fbbf24, #f59e0b);
            }

            section.cldetector-block .alarm2 {
                background: linear-gradient(180deg, #fb7185, #e11d48);
            }

            section.cldetector-block .s1 {
                right: 5%;
                bottom: 5%;
            }

            section.cldetector-block .s2 {
                right: 5%;
                top: 5%;
            }

            section.cldetector-block .s3 {
                left: 10%;
                bottom: 5%;
            }

            section.cldetector-block .s4 {
                left: 10%;
                top: 5%;
            }

            /* dosing room: วงกลมอยู่บน ค่าอยู่ล่าง */
            section.cldetector-block .det.det-stack {
                flex-direction: column;
                align-items: center;
                gap: 6px;
            }

                section.cldetector-block .det.det-stack .pill {
                    min-width: 42px;
                    height: 24px;
                    padding: 0 8px;
                    font-size: 11px;
                }

            section.cldetector-block .d1 {
                right: -5%;
                top: 38%;
            }

            section.cldetector-block .d2
            {
                left: 0%;
                top: 38%;
            }

            section.cldetector-block .legend {
                margin-top: 10px;
                display: flex;
                gap: 16px;
                flex-wrap: wrap;
                color: rgba(230,238,248,.86);
                font-size: 11px;
                flex: 0 0 auto;
            }

            section.cldetector-block .legend-item {
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

            section.cldetector-block .legend-dot {
                width: 12px;
                height: 12px;
                border-radius: 999px;
                border: 1px solid rgba(255,255,255,.8);
                box-shadow: 0 0 0 2px rgba(255,255,255,.08);
            }

            section.cldetector-block .pill.value-normal {
                background: linear-gradient(180deg, rgba(28,36,52,.96), rgba(14,20,33,.98));
                color: #f4f8ff;
            }

            section.cldetector-block .pill.value-alarm1 {
                background: linear-gradient(180deg, #fbbf24, #f59e0b);
                color: #fff;
                border-color: rgba(255,255,255,.14);
            }

            section.cldetector-block .pill.value-alarm2 {
                background: linear-gradient(180deg, #fb7185, #e11d48);
                color: #fff;
                border-color: rgba(255,255,255,.14);
            }

            section.cldetector-block .pill.value-na {
                background: linear-gradient(180deg, rgba(70,78,92,.85), rgba(36,42,54,.92));
                color: rgba(255,255,255,.82);
            }

        @@media (max-width: 1100px) {
            section.cldetector-block .cld-wrap {
                height: auto;
                min-height: 0;
                max-height: none;
                grid-template-columns: 1fr;
            }
        }
    </style>

    <div class="bb-section-h">
        <div class="left">
            <div class="title">CL DETECTOR</div>
        </div>
        <div class="right-icons">
            <button class="bb-ico" type="button" title="Bell" aria-label="Bell">
                <span>🔔</span>
            </button>
            <button class="bb-ico" type="button" title="Settings" aria-label="Settings">
                <span>⚙️</span>
            </button>
        </div>
    </div>

    <div class="bb-section-b">
        <div class="cld-wrap">

            <!-- CHEM1 -->
            <div class="cld-panel" data-cl-panel="CHEM1">
                <div class="cld-head">Chlorine detector CHEM1</div>
                <div class="cld-body">
                    <div class="cld-map">

                        <div class="room storage">
                            <div class="room-title">STORAGE<br>ROOM</div>
                            <div class="door storage-door-left"></div>
                            <div class="door storage-door-top"></div>

                            <div class="det s1" data-stream="CHEM1" data-param="cl_S1">
                                <div class="pill" data-role="value">--</div>
                                <div class="dot" data-role="dot">1</div>
                            </div>

                            <div class="det s2" data-stream="CHEM1" data-param="cl_S2">
                                <div class="pill" data-role="value">--</div>
                                <div class="dot" data-role="dot">2</div>
                            </div>

                            <div class="det s3" data-stream="CHEM1" data-param="cl_S3">
                                <div class="pill" data-role="value">--</div>
                                <div class="dot" data-role="dot">3</div>
                            </div>

                            <div class="det s4" data-stream="CHEM1" data-param="cl_S4">
                                <div class="pill" data-role="value">--</div>
                                <div class="dot" data-role="dot">4</div>
                            </div>
                        </div>

                        <div class="room dosing">
                            <div class="room-title">DOSING<br>ROOM</div>
                            <div class="door dosing-door-top"></div>

                            <div class="det det-stack d1" data-stream="CHEM1" data-param="cl_D1">
                                <div class="dot" data-role="dot">1</div>
                                <div class="pill" data-role="value">--</div>
                            </div>

                            <div class="det det-stack d2" data-stream="CHEM1" data-param="cl_D2">
                                <div class="dot" data-role="dot">2</div>
                                <div class="pill" data-role="value">--</div>
                            </div>
                        </div>

                    </div>

                    <div class="legend">
                        <span class="legend-item">
                            <span class="legend-dot normal"></span>Normal
                        </span>
                        <span class="legend-item">
                            <span class="legend-dot alarm1"></span>Alarm lv1
                        </span>
                        <span class="legend-item">
                            <span class="legend-dot alarm2"></span>Alarm lv2
                        </span>
                    </div>
                </div>
            </div>

            <!-- CHEM2 -->
            <div class="cld-panel" data-cl-panel="CHEM2">
                <div class="cld-head">Chlorine detector CHEM2</div>
                <div class="cld-body">
                    <div class="cld-map">

                        <div class="room storage">
                            <div class="room-title">STORAGE<br>ROOM</div>
                            <div class="door storage-door-left"></div>
                            <div class="door storage-door-top"></div>

                            <div class="det s1" data-stream="CHEM2" data-param="cl_S1">
                                <div class="pill" data-role="value">--</div>
                                <div class="dot" data-role="dot">1</div>
                            </div>

                            <div class="det s2" data-stream="CHEM2" data-param="cl_S2">
                                <div class="pill" data-role="value">--</div>
                                <div class="dot" data-role="dot">2</div>
                            </div>

                            <div class="det s3" data-stream="CHEM2" data-param="cl_S3">
                                <div class="pill" data-role="value">--</div>
                                <div class="dot" data-role="dot">3</div>
                            </div>

                            <div class="det s4" data-stream="CHEM2" data-param="cl_S4">
                                <div class="pill" data-role="value">--</div>
                                <div class="dot" data-role="dot">4</div>
                            </div>
                        </div>

                        <div class="room dosing">
                            <div class="room-title">DOSING<br>ROOM</div>
                            <div class="door dosing-door-top"></div>

                            <div class="det det-stack d1" data-stream="CHEM2" data-param="cl_D1">
                                <div class="dot" data-role="dot">1</div>
                                <div class="pill" data-role="value">--</div>
                            </div>

                            <div class="det det-stack d2" data-stream="CHEM2" data-param="cl_D2">
                                <div class="dot" data-role="dot">2</div>
                                <div class="pill" data-role="value">--</div>
                            </div>
                        </div>

                    </div>

                    <div class="legend">
                        <span class="legend-item">
                            <span class="legend-dot normal"></span>Normal
                        </span>
                        <span class="legend-item">
                            <span class="legend-dot alarm1"></span>Alarm lv1
                        </span>
                        <span class="legend-item">
                            <span class="legend-dot alarm2"></span>Alarm lv2
                        </span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
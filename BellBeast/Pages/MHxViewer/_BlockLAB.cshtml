<style>
    /* =========================
           LAB block - based on DPS structure
           ========================= */

    section.lab-block .bb-section-h,
    section.lab-block .bb-section-h .right-icons {
        position: relative;
        z-index: 99999 !important;
        pointer-events: auto !important;        
    }

    section.lab-block #labBtnSettings,
    section.lab-block .bb-ico {
        position: relative;
        z-index: 100000 !important;
        pointer-events: auto !important;
    }

    section.lab-block .lab-layout {
        display: grid;
        gap: 10px;        
    }

    /* ===== ROW 1 ===== */
    section.lab-block .lab-top-grid {
        display: grid;
        grid-template-columns: 3fr 2.5fr 4.5fr;
        gap: 4px;
        align-items: stretch;
    }

    section.lab-block .lab-top-card,
    section.lab-block .mini-card {
        border-radius: 10px;
        background: rgba(255,255,255,.025);
        border: 1px solid rgba(255,255,255,.08);
        padding: 5px;
        min-width: 0;
    }

    section.lab-block .lab-top-card {
        min-height: 130px;
    }

    section.lab-block .lab-top-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0px;
        margin-bottom: 2px;
    }

    section.lab-block .lab-top-title {
        font-size: 14px;
        font-weight: 700;
        color: #f3f4f6;
        line-height: 1.2;
    }

    section.lab-block .lab-top-sub {
        font-size: 12px;
        color: rgba(255,255,255,.62);
        margin-top: 4px;
    }

    section.lab-block .chart-box,
    section.lab-block .mini-chart {
        position: relative;
        border-radius: 12px;
        border: 1px dashed rgba(255,255,255,.18);
        background: rgba(255,255,255,.04);
        overflow: hidden;
    }

    section.lab-block .chart-box {
        height: 125px;
        min-height: 125px;
    }

    section.lab-block .mini-chart {
        height: 120px;
        min-height: 120px;
    }

        section.lab-block .chart-box canvas,
        section.lab-block .mini-chart canvas {
            width: 100% !important;
            height: 100% !important;
            display: block !important;
        }

    /* ===== recommend table ===== */
    section.lab-block .lab-table-wrap {
        margin-top: 24px;
    }

    section.lab-block .lab-recommend-table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 10px;
        table-layout: fixed;
    }

        section.lab-block .lab-recommend-table th,
        section.lab-block .lab-recommend-table td {
            padding: 9px 10px;
            border-bottom: 1px solid rgba(255,255,255,.08);
            text-align: left;
            font-size: 13px;
        }

        section.lab-block .lab-recommend-table thead th {
            background: rgba(255,255,255,.03);
            color: #f8fafc;
            font-weight: 700;
        }

        section.lab-block .lab-recommend-table tbody td {
            color: rgba(255,255,255,.84);
        }

        section.lab-block .lab-recommend-table tbody tr:last-child td {
            border-bottom: none;
        }

    /* ===== status 4x4 ===== */
    section.lab-block .status-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 2px;
        margin-top: 2px;
        margin-bottom: 2px;
    }

    section.lab-block .status-pill {
        display: flex;
        align-items: center;
        gap: 4px;
        min-height: 20px;
        padding: 8px 10px;
        border-radius: 10px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        color: #e5e7eb;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    section.lab-block .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        flex: 0 0 10px;
    }

        section.lab-block .status-dot.ok {
            background: #22c55e;
            box-shadow: 0 0 10px rgba(34,197,94,.50);
        }

        section.lab-block .status-dot.warn {
            background: #f59e0b;
            box-shadow: 0 0 10px rgba(245,158,11,.45);
        }

        section.lab-block .status-dot.bad {
            background: #ef4444;
            box-shadow: 0 0 10px rgba(239,68,68,.45);
        }

    /* ===== ROW 2 ===== */
    section.lab-block .filter-row {
        display: flex;
        justify-content: flex-start;
        gap: 10px;
        flex-wrap: wrap;
    }

    section.lab-block .filter-btn {
        appearance: none;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255, 153, 51, .5);
        color: #f9fafb;
        border-radius: 10px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: .15s ease;
    }

        section.lab-block .filter-btn:hover {
            background: rgba(255,255,255,.09);
        }

        section.lab-block .filter-btn.active {
            background: rgba(255, 153, 51, 1);
            border-color: rgba(255,255,255,.20);
        }

    /* ===== ROW 3 ===== */
    section.lab-block .cards-row {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    section.lab-block .mini-card .ov-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        margin-bottom: 8px;
    }

    section.lab-block .mini-card .ov-title {
        font-size: 13px;
        font-weight: 700;
        color: #f3f4f6;
    }

    section.lab-block .mini-card .ov-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 44px;
        height: 24px;
        padding: 0 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
    }

        section.lab-block .mini-card .ov-status.ok {
            background: rgba(34,197,94,.16);
            color: #86efac;
        }

        section.lab-block .mini-card .ov-status.bad {
            background: rgba(239,68,68,.16);
            color: #fca5a5;
        }

        section.lab-block .mini-card .ov-status.warn {
            background: rgba(245,158,11,.16);
            color: #fcd34d;
        }

    section.lab-block .mini-meta {
        margin-top: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        font-size: 12px;
        color: rgba(255,255,255,.62);
    }

    section.lab-block .lab-update {
        font-size: 12px;
        color: rgba(255,255,255,.62);
        margin-left: auto;
    }

    /* ===== settings popup overlay ===== */
    .lab-settings-overlay {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,.28);
        z-index: 200000;
    }

        .lab-settings-overlay.show {
            display: flex;
        }

    /* ===== settings popup ===== */
    .lab-settings-pop {
        width: 300px;
        max-width: calc(100vw - 24px);
        border-radius: 16px;
        background: linear-gradient(180deg, #1f2937 0%, #182231 100%);
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 18px 44px rgba(0,0,0,.42);
        padding: 14px;
    }

    .lab-settings-title {
        font-size: 15px;
        font-weight: 700;
        color: #f9fafb;
        margin-bottom: 12px;
    }

    .lab-settings-row {
        display: grid;
        gap: 6px;
        margin-bottom: 12px;
    }

        .lab-settings-row label {
            font-size: 12px;
            color: rgba(255,255,255,.82);
            font-weight: 600;
        }

        .lab-settings-row select {
            width: 100%;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,.12);
            background: rgba(255,255,255,.07);
            color: #f9fafb;
            padding: 10px 12px;
            outline: none;
            transition: border-color .15s ease, background .15s ease, box-shadow .15s ease;
        }

            .lab-settings-row select:focus {
                border-color: rgba(255,255,255,.22);
                background: rgba(255,255,255,.10);
                box-shadow: 0 0 0 3px rgba(255,255,255,.06);
            }

    .lab-settings-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        margin-top: 10px;
    }

        .lab-settings-actions button,
        .lab-settings-row button {
            border: 1px solid rgba(255,255,255,.12);
            background: linear-gradient(180deg, rgba(255,255,255,.11), rgba(255,255,255,.06));
            color: #f9fafb;
            border-radius: 10px;
            padding: 8px 12px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: transform .12s ease, background .12s ease, border-color .12s ease, box-shadow .12s ease;
        }

            .lab-settings-actions button:hover,
            .lab-settings-row button:hover {
                background: linear-gradient(180deg, rgba(255,255,255,.17), rgba(255,255,255,.09));
                border-color: rgba(255,255,255,.18);
                box-shadow: 0 6px 16px rgba(0,0,0,.20);
            }

            .lab-settings-actions button:active,
            .lab-settings-row button:active {
                transform: translateY(1px);
            }

        .lab-settings-actions .primary,
        .lab-settings-row .primary {
            background: linear-gradient(180deg, #ffb347 0%, #ff972f 100%);
            border-color: rgba(255,179,71,.55);
            color: #fff;
            box-shadow: 0 8px 18px rgba(255,159,47,.22);
        }

            .lab-settings-actions .primary:hover,
            .lab-settings-row .primary:hover {
                background: linear-gradient(180deg, #ffc067 0%, #ffa642 100%);
                border-color: rgba(255,192,103,.72);
            }

    .lab-settings-row input[type="checkbox"] {
        accent-color: #ff9f2f;
    }


    /* dropdown box */
    .lab-settings-row select {
        width: 100%;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(255,255,255,.07);
        color: #f9fafb;
        padding: 10px 12px;
        outline: none;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
    }

    /* dropdown list items */
    .lab-settings-row select option {
        background: #1f2937;
        color: #f9fafb;
    }

    /* selected / focus state */
    .lab-settings-row select:focus {
        border-color: rgba(255,255,255,.22);
        box-shadow: 0 0 0 3px rgba(255,255,255,.06);
    }


    /* ===== responsive ===== */
    @@media (max-width: 1280px) {
        section.lab-block .lab-top-grid {
            grid-template-columns: 1fr 1fr;
        }

            section.lab-block .lab-top-grid > .lab-top-card:last-child {
                grid-column: 1 / -1;
            }

        section.lab-block .cards-row {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 820px) {
        section.lab-block .lab-top-grid,
        section.lab-block .cards-row {
            grid-template-columns: 1fr;
        }

        section.lab-block .status-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
</style>

<section class="bb-section lab-block"
         data-lab-summary-url="/api/lab/summary"
         data-lab-refresh-sec="10">
    <div class="bb-section-h">
        <div class="left">
            <div class="title">LAB</div>
        </div>


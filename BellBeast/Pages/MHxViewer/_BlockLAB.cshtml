            <!-- ROW 2 -->
            <div class="filter-row">
                <button class="filter-btn active" type="button" data-filter="cw_turbid">CW Turbid</button>
                <button class="filter-btn" type="button" data-filter="cw_precl">CW Pre CL</button>
                <button class="filter-btn" type="button" data-filter="fw_turbid">FW Turbid</button>
                <button class="filter-btn" type="button" data-filter="tw_turbid">TW Turbid</button>
                <button class="filter-btn" type="button" data-filter="tw_postcl">TW Pos CL</button>
            </div>

            <!-- ROW 3 -->
            <div class="cards-row">
                <div class="mini-card">
                    <div class="ov-top">
                        <div class="ov-title" id="labCardTitle1">CW Turbid #1</div>
                        <div class="ov-status ok" id="labCardStatus1">OK</div>

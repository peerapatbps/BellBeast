                            <div class="lab-top-title">RECOMMEND DOSE (mg/L)</div>
                        </div>
                    </div>

                    <div class="lab-table-wrap">
                        <table class="lab-recommend-table">
                            <thead>
                                <tr>
                                    <th style="width:36%;">TYPE</th>
                                    <th style="width:32%;">P12</th>
                                    <th style="width:32%;">P34</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>PACL</td>
                                    <td id="labDosePaclP12">-</td>
                                    <td id="labDosePaclP34">-</td>
                                </tr>
                                <tr>
                                    <td>ALUM</td>

            </button>
            <button class="bb-ico" id="labBtnSettings" type="button" title="Settings" aria-label="Settings">
                <span>⚙️</span>
            </button>
        </div>
    </div>

    <div class="bb-section-b">
        <div class="lab-layout">

            <!-- ROW 1 -->
            <div class="lab-top-grid">
                <!-- column 1 : chart -->
                <div class="lab-top-card">
                    <div class="lab-top-head">
                        <div>
                            <div class="lab-top-title">RW Turbid (NTU) vs Temp (°C)</div>
                        </div>

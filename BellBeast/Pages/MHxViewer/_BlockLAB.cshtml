                        </div>
                    </div>

                    <div class="status-grid" id="labStatusGrid">
                        <div class="status-pill"><span class="status-dot ok"></span>CW1 T</div>
                        <div class="status-pill"><span class="status-dot ok"></span>CW2 T</div>
                        <div class="status-pill"><span class="status-dot ok"></span>CW3 T</div>
                        <div class="status-pill"><span class="status-dot ok"></span>CW4 T</div>

                        <div class="status-pill"><span class="status-dot ok"></span>CW1 CL</div>
                        <div class="status-pill"><span class="status-dot ok"></span>CW2 CL</div>
                        <div class="status-pill"><span class="status-dot ok"></span>CW3 CL</div>
                        <div class="status-pill"><span class="status-dot ok"></span>CW4 CL</div>

                        <div class="status-pill"><span class="status-dot ok"></span>FW1 T</div>
                        <div class="status-pill"><span class="status-dot ok"></span>FW2 T</div>
                        <div class="status-pill"><span class="status-dot ok"></span>FW3 T</div>
                        <div class="status-pill"><span class="status-dot ok"></span>FW4 T</div>

                        <div class="status-pill"><span class="status-dot ok"></span>TW1 CL</div>
                        <div class="status-pill"><span class="status-dot ok"></span>TW2 CL</div>
                        <div class="status-pill"><span class="status-dot ok"></span>TW3 CL</div>
                        <div class="status-pill"><span class="status-dot ok"></span>TW4 CL</div>
                    </div>

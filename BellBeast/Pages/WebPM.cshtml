@page
@model BellBeast.Pages.WebPMModel
@{
    ViewData["Title"] = "Wayfarer PM Dashboard";
    ViewData["ContentClass"] = "content content-wide";
}

@section Styles {
    <link rel="stylesheet" href="~/css/wayfarer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/wayfarer-filter-tabs-v2.css" asp-append-version="true" />
}

<section id="wayfarerApp" class="wf-page" data-api-base="/api/wayfarer">
    <section class="wf-hero" aria-label="Dashboard header">
        <div class="wf-hero-top">
            <div>
                <div class="wf-eyebrow">WEBPM / WAYFARER</div>
                <h1>PM Work Order Dashboard</h1>
                <p>ค้นหา กรอง และตรวจสอบรายละเอียด Work Order สำหรับจัดทำ template และ demo view</p>
            </div>

            <div class="wf-hero-actions">
                <button type="button" id="wfRefreshBtn" class="wf-btn wf-btn-primary">Refresh</button>
                <button type="button" id="wfExportBtn" class="wf-btn wf-btn-ghost" disabled>Export Workbook</button>
            </div>
        </div>

        <div class="wf-kpi-grid" aria-label="Wayfarer KPI">
            <article class="wf-kpi-card wf-kpi-card-total"><span>Total WO</span><strong id="wfKpiTotal">-</strong><small>ตาม filter ปัจจุบัน</small></article>
            <article class="wf-kpi-card wf-kpi-card-waiting"><span>Waiting / Open</span><strong id="wfKpiWaiting">-</strong><small>Status code 10, 15, 20</small></article>
            <article class="wf-kpi-card wf-kpi-card-scheduled"><span>Scheduled</span><strong id="wfKpiScheduled">-</strong><small>Status code 30</small></article>
            <article class="wf-kpi-card wf-kpi-card-progress"><span>In Progress</span><strong id="wfKpiProgress">-</strong><small>Status code 50</small></article>
            <article class="wf-kpi-card wf-kpi-card-completed"><span>Completed</span><strong id="wfKpiDone">-</strong><small>Status code 70, 80, 99 or complete_date exists</small></article>
        </div>
    </section>

    <section class="wf-panel wf-filter-panel wf-mode-panel" aria-label="Filter box">
        <div class="wf-section-head">
            <div>
                <div class="wf-eyebrow">FILTER MODE</div>
                <h2>Filter box</h2>
            </div>
            <button type="button" id="wfResetBtn" class="wf-btn wf-btn-ghost">Reset filter</button>
        </div>

        <input type="hidden" id="wfActiveFilterMode" value="og" />

        <div class="wf-filter-mode-row">
            <div class="wf-filter-group wf-filter-group-shared" aria-label="Shared date range filter">
                <span class="wf-tab-kicker">DATE FILTER RANGE</span>
                <div class="wf-filter-date-grid">
                    <label class="wf-field">
                        <span>From</span>
                        <span class="wf-date-box">
                            <input id="wfFrom" type="date" />
                        </span>
                    </label>
                    <label class="wf-field">
                        <span>To</span>
                        <span class="wf-date-box">
                            <input id="wfTo" type="date" />
                        </span>
                    </label>
                </div>
            </div>

            <button type="button" id="wfTabOg" class="wf-tab-btn is-active" role="tab"
                    aria-selected="true" aria-controls="wfOgFilterTab" data-wf-mode="og">
                <span class="wf-tab-kicker">STANDARD QUERY</span>
                <strong>Work Order Search</strong>
                <small>ค้นหาใบงานด้วยคำสำคัญ สถานะ ประเภทงาน และหน่วยงาน</small>
            </button>

            <button type="button" id="wfTabMhMap" class="wf-tab-btn" role="tab"
                    aria-selected="false" aria-controls="wfMhMapFilterTab" data-wf-mode="mhmap">
                <span class="wf-tab-kicker">SPATIAL VIEW</span>
                <strong>Mahasawat Plant Map</strong>
                <small>แสดงและคัดกรองใบงานตามตำแหน่งอุปกรณ์บนแผนผังโรงงาน</small>
            </button>
        </div>

        <div id="wfOgFilterTab" class="wf-tab-page is-active" role="tabpanel" aria-labelledby="wfTabOg" data-wf-filter-mode="og">
            <div class="wf-filter-main">
                <label class="wf-field wf-field-search"><span>Search</span><input id="wfSearch" type="search" placeholder="WO No, WO Code, ปัญหา, อุปกรณ์, หน่วยงาน..." autocomplete="off" /></label>
                <label class="wf-field"><span>Status</span><select id="wfStatus"><option value="">All status</option></select></label>
                <label class="wf-field"><span>Type</span><select id="wfType"><option value="">All type</option></select></label>
                <label class="wf-field"><span>Dept</span><select id="wfDept"><option value="">All dept</option></select></label>
            </div>

            <div class="wf-filter-sub">
                <label class="wf-field wf-field-small"><span>Sort</span><select id="wfSort"><option value="wo_date">WO Date</option><option value="wo_no">WO No</option><option value="status">Status</option><option value="type">Type</option><option value="dept">Dept</option><option value="fetched">Fetched</option></select></label>
                <label class="wf-field wf-field-small"><span>Direction</span><select id="wfDir"><option value="desc">DESC</option><option value="asc">ASC</option></select></label>
                <label class="wf-field wf-field-small"><span>Page size</span><select id="wfPageSize"><option>10</option><option selected>25</option><option>50</option><option>100</option></select></label>
            </div>
        </div>

        <div id="wfMhMapFilterTab" class="wf-tab-page" role="tabpanel" aria-labelledby="wfTabMhMap" data-wf-filter-mode="mhmap" hidden>
            <input type="hidden" id="mhMapBranchPuNo" value="" />
            <input type="hidden" id="mhMapBranchCode" value="" />
            <input type="hidden" id="mhMapBranchName" value="" />

            <div class="wf-filter-group wf-filter-group-map" aria-label="MH Map filter controls">
                <div class="wf-filter-group-head">
                    <div>
                        <span class="wf-filter-group-kicker">MAP FILTER</span>
                        <strong>Work Order Status</strong>
                        <small>เลือกสถานะที่ต้องการให้แสดงบนแผนที่และผลลัพธ์ของ branch</small>
                    </div>
                </div>
                <div class="wf-map-status-filter" aria-label="Map work order status filter">
                    <button type="button" class="wf-map-status-toggle is-active" data-map-status="all">
                        All
                    </button>

                    <button type="button" class="wf-map-status-toggle" data-map-status="open">
                        Waiting / Open <small>10, 15, 20</small>
                    </button>

                    <button type="button" class="wf-map-status-toggle" data-map-status="scheduled">
                        Scheduled <small>30</small>
                    </button>

                    <button type="button" class="wf-map-status-toggle" data-map-status="progress">
                        In progress <small>50</small>
                    </button>

                    <button type="button" class="wf-map-status-toggle" data-map-status="completed">
                        Completed <small>70, 80, 99 / complete date</small>
                    </button>
                </div>
            </div>


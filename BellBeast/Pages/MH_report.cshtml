@page
@model MH_reportModel
@{
    ViewData["Title"] = "MH Report";
}

<style>
    .mh-page { width: 1100px; min-width: 1100px; max-width: 1100px; margin: 0 auto; }

    .mh-card {
        border: 1px solid rgba(255,255,255,0.20);
        border-radius: 10px;
        padding: 12px;
        background: rgba(0,0,0,0.10);
        backdrop-filter: blur(4px);
        box-sizing: border-box;
    }

    .mh-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }

    .mh-left { display: flex; align-items: center; gap: 12px; flex-wrap: nowrap; }
    .mh-right { display: flex; align-items: center; gap: 10px; flex-wrap: nowrap; margin-left: auto; }

    .mh-btn {
        appearance: none;
        border: 1px solid rgba(255,255,255,0.22);
        border-radius: 10px;
        padding: 8px 12px;
        font-weight: 700;
        letter-spacing: .2px;
        cursor: pointer;
        user-select: none;
        background: rgba(255,255,255,0.08);
        color: #fff;
        transition: transform .05s ease, background .15s ease, border-color .15s ease;
    }
    .mh-btn:active { transform: translateY(1px); }
    .mh-btn:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.35); }

    .mh-btn-primary { background: rgba(50, 170, 255, 0.28); border-color: rgba(50, 170, 255, 0.55); }
    .mh-btn-primary:hover { background: rgba(50, 170, 255, 0.36); border-color: rgba(50, 170, 255, 0.75); }

    .mh-btn-danger { background: rgba(255, 80, 80, 0.20); border-color: rgba(255, 80, 80, 0.45); }
    .mh-btn-danger:hover { background: rgba(255, 80, 80, 0.28); border-color: rgba(255, 80, 80, 0.65); }

    .mh-params { height: 600px !important; min-height: 600px !important; max-height: 600px !important; overflow: hidden !important; }

    .mh-topline {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 10px;
    }
    .mh-topline .left { font-weight: 700; }
    .mh-topline .right { color: rgba(255,255,255,0.65); font-size: 12px; }

    .mh-blocklist {
        height: 560px;
        min-height: 560px;
        max-height: 560px;
        overflow: auto;
        box-sizing: border-box;
        padding-right: 4px;
    }

    .sec-block {
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 10px;
        padding: 10px;
        margin-bottom: 10px;
        background: rgba(255,255,255,0.03);
        box-sizing: border-box;
    }

    .sec-title { font-weight: 800; margin-bottom: 6px; letter-spacing: .3px; }

    .grp-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin: 6px 0 4px 6px;
    }

    .grp-title { font-weight: 700; color: rgba(255,255,255,0.90); }

    .grp-actions { display: flex; gap: 8px; margin-left: auto; }

    .mh-btn-mini {
        appearance: none;
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 8px;
        padding: 3px 8px;
        font-weight: 700;
        cursor: pointer;
        background: rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.90);
        font-size: 12px;
        line-height: 1.2;
    }
    .mh-btn-mini:hover { background: rgba(255,255,255,0.10); border-color: rgba(255,255,255,0.30); }

    .mh-items { margin-left: 14px; }

    .mh-item { display: flex; align-items: center; gap: 8px; padding: 3px 0; }
    .mh-item input[type="checkbox"] { transform: translateY(1px); }

    .result-wrap { margin-top: 12px; width: 100%; }
    .result-title { margin-bottom: 8px; font-weight: 700; }

    pre.mh-result {
        height: 200px !important;
        min-height: 200px !important;
        max-height: 200px !important;
        width: 100% !important;
        max-width: 100% !important;
        display: block !important;
        box-sizing: border-box !important;
        margin: 0 !important;
        overflow-y: auto !important;
        overflow-x: auto !important;
        white-space: pre !important;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 12px;
        line-height: 1.35;
    }

    .mh-params, pre.mh-result { flex: 0 0 auto !important; }
</style>

<div class="mh-page">
    <h2>MH Report</h2>

    <div class="mh-toolbar">
        <div class="mh-left">
            <label>
                Start:
                <input type="date" id="startDate" />
            </label>

            <label>
                End:
                <input type="date" id="endDate" />
            </label>
        </div>

        <div class="mh-right">
            <button type="button" class="mh-btn" onclick="selectAll(true)">Select All</button>
            <button type="button" class="mh-btn mh-btn-danger" onclick="selectAll(false)">Clear</button>
            <button type="button" id="btnGenerate" class="mh-btn mh-btn-primary" onclick="submitDailyReport()">Generate</button>
        </div>
    </div>

    <section class="mh-card mh-params">
        <div class="mh-topline">
            <div class="left">Parameters</div>
            <div class="right" id="selCount">Selected: 0/0</div>
        </div>

        <div class="mh-blocklist" id="blockContainer"></div>
    </section>

    <section class="result-wrap">
        <div class="result-title">Result</div>
        <pre id="out" class="mh-card mh-result"></pre>
    </section>
</div>


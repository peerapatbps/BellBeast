  const state = Object.create(null);

  function displayLabel(key, fallbackLabel) {
    const m = PARAM_META[key];
    if (!m) return fallbackLabel;
    const unit = (m.unit || "").trim();
    if (!unit || unit === "-") return m.label;
    return `${m.label} (${unit})`;
  }

  function toIsoDate(d) {
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth() + 1).padStart(2, "0");
    const dd = String(d.getDate()).padStart(2, "0");
    return `${yyyy}-${mm}-${dd}`;
  }

  function getSelectedKeys() {
    return Object.keys(state).filter(k => state[k]);
  }

  function updateSelCount() {
    const total = Object.keys(state).length;
    const sel = getSelectedKeys().length;
    const el = document.getElementById("selCount");
    if (el) el.textContent = `Selected: ${sel}/${total}`;
  }

  function renderCheckboxes() {
    const host = document.getElementById("blockContainer");
    host.innerHTML = "";

    for (const sec of CHECKBOX_SCHEMA) {
      const secDiv = document.createElement("div");
      secDiv.className = "sec-block";

      const secTitle = document.createElement("div");
      secTitle.className = "sec-title";
      secTitle.textContent = sec.title;
      secDiv.appendChild(secTitle);

      for (const grp of sec.groups) {
        const grpRow = document.createElement("div");
        grpRow.className = "grp-row";

        const grpTitle = document.createElement("div");
        grpTitle.className = "grp-title";
        grpTitle.textContent = grp.title;

        const grpActions = document.createElement("div");
        grpActions.className = "grp-actions";

        const btnAll = document.createElement("button");
        btnAll.type = "button";
        btnAll.className = "mh-btn-mini";
        btnAll.textContent = "All";
        btnAll.onclick = () => {
          for (const it of grp.items) state[it.key] = true;
          renderCheckboxes();
          updateSelCount();
        };

        const btnNone = document.createElement("button");
        btnNone.type = "button";
        btnNone.className = "mh-btn-mini";
        btnNone.textContent = "None";
        btnNone.onclick = () => {
          for (const it of grp.items) state[it.key] = false;
          renderCheckboxes();
          updateSelCount();
        };

        grpActions.appendChild(btnAll);
        grpActions.appendChild(btnNone);

        grpRow.appendChild(grpTitle);
        grpRow.appendChild(grpActions);
        secDiv.appendChild(grpRow);

        const itemsBox = document.createElement("div");
        itemsBox.className = "mh-items";

        for (const it of grp.items) {
          const row = document.createElement("label");
          row.className = "mh-item";

          const cb = document.createElement("input");
          cb.type = "checkbox";
          cb.checked = !!state[it.key];
          cb.onchange = () => {
            state[it.key] = cb.checked;
            updateSelCount();
          };

          const txt = document.createElement("span");
          txt.textContent = displayLabel(it.key, it.label);

          row.appendChild(cb);
          row.appendChild(txt);
          itemsBox.appendChild(row);
        }

        secDiv.appendChild(itemsBox);
      }

      host.appendChild(secDiv);
    }
  }

  function init() {
    for (const sec of CHECKBOX_SCHEMA) {
      for (const grp of sec.groups) {
        for (const it of grp.items) state[it.key] = true;
      }
    }

    const startEl = document.getElementById("startDate");
    const endEl = document.getElementById("endDate");
    const today = toIsoDate(new Date());

    startEl.value = today;
    endEl.value = startEl.value;
    endEl.min = startEl.value;

    startEl.addEventListener("change", () => {
      if (!startEl.value) startEl.value = today;
      endEl.min = startEl.value;
      if (!endEl.value || endEl.value < startEl.value) endEl.value = startEl.value;
    });

    endEl.addEventListener("change", () => {
      if (!startEl.value) {
        startEl.value = today;
        endEl.min = startEl.value;
      }
      if (!endEl.value || endEl.value < startEl.value) endEl.value = startEl.value;
    });

    renderCheckboxes();
    updateSelCount();
  }

  function selectAll(on) {
    for (const k in state) state[k] = on;
    renderCheckboxes();
    updateSelCount();
  }

  let isSubmitting = false;

  async function submitDailyReport() {
    if (isSubmitting) return;

    const btn = document.getElementById("btnGenerate");
    const prevText = btn ? btn.textContent : "Generate";

    const startDate = (document.getElementById("startDate").value || "").trim();
    const endDate = (document.getElementById("endDate").value || "").trim();

    if (!startDate) return alert("Please select start date");
    if (!endDate) return alert("Please select end date");
    if (endDate < startDate) return alert("End date must be >= start date");

    const selectedParams = getSelectedKeys();
    if (!selectedParams.length) return alert("Please select at least 1 parameter");

    const payload = { startDate, endDate, selectedParams, source: "MH_report" };

    const out = document.getElementById("out");
    if (out) out.textContent = "Sending request...";

    try {
      isSubmitting = true;
      if (btn) { btn.disabled = true; btn.textContent = "Generating..."; }

      const resp = await fetch("/api/dailyreport", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "text/csv, application/octet-stream, */*"
        },
        body: JSON.stringify(payload)
      });

      if (!resp.ok) {
        if (out) out.textContent = `ERROR\nHTTP ${resp.status} ${resp.statusText}`;
        return;
      }

      const blob = await resp.blob();

      const cd = resp.headers.get("content-disposition") || "";
      let filename = "";
      const m = cd.match(/filename\*=UTF-8''([^;]+)|filename="?([^"]+)"?/i);
      if (m) filename = decodeURIComponent(m[1] || m[2] || "").trim();
      if (!filename) filename = `MH_report_${startDate}_to_${endDate}.csv`;

      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);

      if (out) out.textContent = `OK\nHTTP ${resp.status} ${resp.statusText}\nDownloaded: ${filename}`;
    } catch (e) {
      if (out) out.textContent = `ERROR\n${e && e.message ? e.message : "Exception occurred"}`;
    } finally {
      isSubmitting = false;
      if (btn) { btn.disabled = false; btn.textContent = prevText; }
    }
  }

  // ทำให้ onclick="..." เรียกได้ชัวร์
  window.selectAll = selectAll;
  window.submitDailyReport = submitDailyReport;

  document.addEventListener("DOMContentLoaded", init);
})();
</script>
}
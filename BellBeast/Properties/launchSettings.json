{
    "$schema": "https://json.schemastore.org/launchsettings.json",

    "profiles": {

        "http": {
            "commandName": "Project",
            "launchBrowser": true,
            "dotnetRunMessages": true,
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "applicationUrl": "http://localhost:443;http://0.0.0.0:443"
        },

        "https": {
            "commandName": "Project",
            "launchBrowser": true,
            "dotnetRunMessages": true,
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_HTTPS_PORT": "443"
            },
            "applicationUrl": "https://localhost:443;https://0.0.0.0:443;http://localhost:443;http://0.0.0.0:443"
        },

        "IIS Express": {
            "commandName": "IISExpress",
            "launchBrowser": true,
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    },

    "iisSettings": {
        "windowsAuthentication": false,
        "anonymousAuthentication": true,
        "iisExpress": {
            "applicationUrl": "http://localhost:54851",
            "sslPort": 44324
        }
    }
}
